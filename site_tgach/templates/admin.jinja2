        async function loadFullStats() {
            const tbody = document.getElementById('full-stats-body');
            tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:20px;">Считаем цифры...</td></tr>';
            try {
                const res = await fetch('/api/stats/detailed');
                const data = await res.json();
                let html = '';
                // Сортируем: сначала самые активные за 24ч
                const sortedBoards = Object.keys(data).sort((a,b) => data[b].posts_24h - data[a].posts_24h);
                for (const bid of sortedBoards) {
                    const s = data[bid];
                    // Пропускаем пустые доски, чтобы не засорять (или оставь, если хочешь видеть нули)
                    if (s.total_posts === 0 && s.total_threads === 0) continue;
                    const topThreads = s.top_threads.map(t => 
                        `<div class="stat-thread-item">
                            <a href="/${bid}/res/${t.id}.html" target="_blank" title="${t.title}">
                                <b>#${t.id}:</b> ${t.title}
                            </a>
                        </div>`
                    ).join('');
                    html += `
                    <tr>
                        <td style="font-weight:bold;">/${bid}/</td>
                        <td style="text-align:center; ${s.posts_1h > 0 ? 'color:#2ecc71; font-weight:bold;' : ''}">${s.posts_1h}</td>
                        <td style="text-align:center;">${s.posts_24h}</td>
                        <td style="text-align:center;">${s.threads_24h}</td>
                        <td style="text-align:center;">${s.total_posts}</td>
                        <td>${topThreads}</td>
                    </tr>`;
                }
                tbody.innerHTML = html;
            } catch(e) {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; color:red;">Ошибка</td></tr>';
            }
        }
        let currentInspectorData = null;

        async function inspectPost() {
            const input = document.getElementById('inspect-input').value.trim();
            if (!input) return;

            let postNum = input;
            const match = input.match(/res\/(\d+)\.html/) || input.match(/#post-(\d+)/);
            if (match) postNum = match[1];
            postNum = parseInt(postNum.replace(/\D/g, ''));

            if (!postNum) { alert("Некорректный номер"); return; }

            const res = await fetch('/api/admin/inspect_post', {
                method: 'POST', headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ post_num: postNum })
            });
            
            const json = await res.json();
            if (!json.found) { alert('Пост не найден.'); return; }

            currentInspectorData = json.data;
            const d = json.data;

            document.getElementById('inspector-result').style.display = 'block';
            document.getElementById('ins-num').textContent = d.post_num;
            document.getElementById('ins-board').textContent = d.board_id;
            document.getElementById('ins-scope-board').textContent = d.board_id; // Обновляем лейбл в радио
            document.getElementById('ins-uid').textContent = d.author_id;
            document.getElementById('ins-hash').textContent = json.user_hash;
            
            document.getElementById('ins-date').textContent = new Date(d.timestamp * 1000).toLocaleString();
            document.getElementById('ins-total-posts').textContent = d.total_posts;

            const content = d.content.text || '';
            document.getElementById('ins-text').textContent = content.substring(0, 500);

            // Файлы
            const filesDiv = document.getElementById('ins-files');
            filesDiv.innerHTML = '';
            if (d.content.files) {
                d.content.files.forEach(f => {
                    const img = document.createElement('img');
                    img.src = f.thumbnail_url || f.original_url;
                    img.style.height = '60px';
                    img.style.border = '1px solid #555';
                    filesDiv.appendChild(img);
                });
            }

            // История
            const histDiv = document.getElementById('ins-history-list');
            histDiv.innerHTML = '';
            if (d.history && d.history.length > 0) {
                d.history.forEach(h => {
                    const date = new Date(h.timestamp * 1000).toLocaleDateString();
                    const row = document.createElement('div');
                    row.style.borderBottom = '1px solid var(--border-input)';
                    row.style.padding = '4px 0';
                    // Ссылка на пост
                    const link = `/${h.board_id}/res/${h.thread_id || h.post_num}.html#post-${h.post_num}`;
                    row.innerHTML = `
                        <span style="color:var(--text-secondary)">[${date}]</span> 
                        <b>/${h.board_id}/</b> 
                        <a href="${link}" target="_blank">#${h.post_num}</a>: 
                        ${h.preview}
                    `;
                    histDiv.appendChild(row);
                });
            } else {
                histDiv.innerHTML = 'История пуста.';
            }
        }
        async function loadBans() {
            const tbody = document.getElementById('bans-table-body');
            if (!tbody) return;
            tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;">Загрузка...</td></tr>';
            try {
                const res = await fetch('/api/admin/banned_files');
                const list = await res.json();
                tbody.innerHTML = '';
                
                if (list.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding:30px; color:gray; font-size:1.2em;">🍃 Бан-лист пуст</td></tr>';
                    return;
                }
                
                list.forEach(item => {
                    let preview = '<span style="color:#555">Нет превью</span>';
                    if (item.example_file_id) {
                        preview = `<a href="/files/${item.example_file_id}" target="_blank"><img src="/files/${item.example_file_id}" style="height:50px; width:50px; object-fit:cover; border-radius:4px;" referrerpolicy="no-referrer"></a>`;
                    }
                    const tr = document.createElement('tr');
                    tr.style.borderBottom = '1px solid #444';
                    tr.innerHTML = `
                        <td style="padding:5px;">${preview}</td>
                        <td style="padding:5px;"><span style="font-weight:bold; color:${item.hash_type==='phash'?'#e67e22':'#3498db'}">${item.hash_type}</span><br><span style="font-family:monospace; font-size:0.8em; opacity:0.7">${item.hash_value.substring(0, 15)}...</span></td>
                        <td style="padding:5px;">${item.reason || '-'}</td>
                        <td style="padding:5px;"><button class="btn btn-secondary" onclick="unbanHash('${item.hash_value}')" style="font-size:0.8em; padding:2px 8px;">Разбанить</button></td>
                    `;
                    tbody.appendChild(tr);
                });
            } catch (e) {
                tbody.innerHTML = '<tr><td colspan="4" style="color:red; text-align:center;">Ошибка загрузки</td></tr>';
            }
        }

        async function unbanHash(hash) {
            if(!confirm('Разбанить этот файл?')) return;
            await fetch('/api/admin/unban_file', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ hash_value: hash })
            });
            loadBans();
