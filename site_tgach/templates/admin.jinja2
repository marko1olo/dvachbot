            <div id="firewall" class="tab-pane">
                <h2>🧱 Управление Файерволом (Trap Mode)</h2>
                <p>Здесь можно вручную отправить подозрительные IP в бесконечную ловушку («черную дыру»).</p>
                
                <div class="admin-section" style="background: var(--bg-input); padding: 20px; border-radius: 8px; border: 1px solid var(--border-input);">
                    <form id="admin-troll-form" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; align-items: flex-end;">
                        <div class="form-group">
                            <label>IP Адрес:</label>
                            <input type="text" name="ip" id="troll-ip-input" placeholder="5.189.173.122" required>
                        </div>
                        <div class="form-group">
                            <label>Режим ловушки:</label>
                            <select name="mode" id="troll-mode-select">
                                <option value="gzip">📦 GZIP Бомба (RAM Killer)</option>
                                <option value="html">🌐 HTML Depth (DOM Killer)</option>
                                <option value="xml">🧬 XML Tarpit (Scanner Killer)</option>
                                <option value="js">📜 JS Infinity (Engine Killer)</option>
                                <option value="slow" selected>🐌 Slow Loris (Connection Killer)</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Длительность:</label>
                            <select name="duration" id="troll-duration-select">
                                <option value="3600">1 час</option>
                                <option value="86400" selected>24 часа</option>
                                <option value="604800">7 дней</option>
                                <option value="2592000">30 дней</option>
                                <option value="315360000">Навсегда</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary" style="grid-column: span 3; background: #e74c3c; border-color: #c0392b; font-weight: bold; margin-top: 10px;">🚀 Активировать Ловушку</button>
                    </form>
                </div>

                <h3 style="margin-top: 25px;">🎯 Активные Ловушки</h3>
                <div id="troll-active-list" style="margin-top: 10px;">
                    <p style="color:gray;">Загрузка списка...</p>
                </div>
            </div>

            <div id="reports" class="tab-pane">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h2>🚨 Активные жалобы</h2>
                    <button class="btn btn-secondary" onclick="loadReports()">🔄 Обновить</button>
                </div>
                <div id="reports-list" style="display: flex; flex-direction: column; gap: 15px;">
                    <p style="padding: 20px; text-align: center; color: var(--text-secondary);">Загрузка...</p>
                </div>
            </div>
            <div id="inbox" class="tab-pane">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h2>📬 Сообщения от пользователей</h2>
                    <button class="btn btn-secondary" onclick="AdminManager.loadFeedback()">🔄 Обновить</button>
                </div>
                <div id="feedback-list" class="feedback-grid">
                    <p style="padding: 20px; text-align: center; color: var(--text-secondary);">Загрузка писем...</p>
                </div>
            </div>
        </section>
    </div>
    <script src="/static/js/main.js?v=2.0"></script>
    <script src="/static/js/admin.js?v=1.0"></script>
    <script>
        let activityChartInstance = null;
        const AdminFeed = {
            socket: null,
            init() {
                if (this.socket && this.socket.readyState <= 1) return;
                
                const proto = location.protocol === 'https:' ? 'wss' : 'ws';
                this.socket = new WebSocket(`${proto}://${location.host}/ws/admin/feed`);
                
                this.socket.onopen = () => console.log('⚡ Admin Feed Connected');
                
                this.socket.onmessage = (event) => {
                    try {
                        const data = JSON.parse(event.data);
                        this.render(data);
                    } catch(e) { console.error(e); }
                };
                
                this.socket.onclose = () => {
                    console.log('⚡ Feed Disconnected. Reconnecting...');
                    setTimeout(() => this.init(), 3000);
                };
            },
            render(post) {
                const container = document.getElementById('admin-live-feed');
                if (!container) return;
                const timeStr = new Date(post.timestamp * 1000).toLocaleTimeString();
                let content = post.content.text || '[Файл]';
                if (content.length > 150) content = content.substring(0, 150) + '...';
                const div = document.createElement('div');
                div.style.cssText = "border-bottom:1px solid #333; padding:4px 0; font-family:monospace; font-size:12px; animation: flash-highlight 1s;";
                div.innerHTML = `
                    <span style="color:#2ecc71">[LIVE ${timeStr}]</span> 
                    <span style="color:orange">/${post.board_id}/</span> 
                    <a href="/${post.board_id}/res/0.html#post-${post.id}" target="_blank" style="color:#3498db">#${post.id}</a> 
                    <b>(ID: ${post.author_id})</b>: ${content}
                `;
                
                container.appendChild(div);
                container.scrollTop = container.scrollHeight;
                if (container.children.length > 200) {
                    container.firstChild.remove();
                }
            }
        };
        function openTab(tabId) {
            document.querySelectorAll('.tab-pane').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.admin-nav-btn').forEach(el => el.classList.remove('active'));
            const tab = document.getElementById(tabId);
            if (tab) tab.classList.add('active');
            const buttons = document.querySelectorAll('.admin-nav-btn');
            buttons.forEach(btn => { 
                const clickAttr = btn.getAttribute('onclick');
                if(clickAttr && clickAttr.includes(`'${tabId}'`)) btn.classList.add('active'); 
            });
            if (tabId === 'dashboard') { loadStats(); updateServerHealth(); }
            if (tabId === 'boards') loadBoardsList(); 
            if (tabId === 'logs') loadLogs();
            if (tabId === 'requests') loadImportRequests(); 
            if (tabId === 'import') loadActiveSimulations();
            if (tabId === 'users' && typeof AdminManager !== 'undefined') AdminManager.loadAlertsHistory();
            if (tabId === 'reports') loadReports();
            if (tabId === 'fullstats') loadFullStats();
            if (tabId === 'spamfilter') loadSpamWords();
            if (tabId === 'inbox' && typeof AdminManager !== 'undefined') AdminManager.loadFeedback();
            if (tabId === 'firewall' && typeof AdminManager !== 'undefined') AdminManager.loadTrollList();
            if (tabId === 'bans') loadBans();
            if (tabId === 'mod_queue') loadModQueue();
            if (tabId === 'livefeed') {
                loadLiveFeedHistory(); 
                if (typeof AdminFeed !== 'undefined') AdminFeed.init();
            }
            if (tabId === 'graphs') {
                setTimeout(loadGraphs, 100); 
            }
            if (tabId === 'settings') {
                if (typeof AdminManager !== 'undefined' && AdminManager.loadSystemSettings) {
                    AdminManager.loadSystemSettings();
                }
                fetch('/api/admin/get_announcement')
                    .then(r => r.json())
                    .then(d => {
                        const input = document.getElementById('announcement-input');
                        if(input) input.value = d.text || "";
                    });

                fetch('/api/admin/lockdown_status')
                    .then(r => r.json())
                    .then(d => {
                        document.getElementById('lockdown-toggle').checked = d.enabled;
                    });
                
                fetch('/api/admin/neuro_status')
                    .then(r => r.json())
                    .then(d => {
                        document.getElementById('neuro-toggle').checked = d.enabled;
                    });

                fetch('/api/admin/scanner_status')
                    .then(r => r.json())
                    .then(d => {
                        const toggle = document.getElementById('scanner-toggle');
                        if(toggle) toggle.checked = d.enabled;
                        const input = document.getElementById('scanner-interval');
                        if(input) input.value = d.interval || 66; 
                    });

                fetch('/api/captcha/status')
                    .then(r => r.json())
                    .then(d => {
                        const el = document.getElementById('captcha-toggle');
                        if(el) el.checked = d.enabled;
                    });

            }
        }
        async function saveAnnouncement(clear=false) {
            const text = clear ? "" : document.getElementById('announcement-input').value;
            try {
                await fetch('/api/admin/set_announcement', {
                    method: 'POST', headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ text: text })
                });
                alert('Сохранено');
                if(clear) document.getElementById('announcement-input').value = "";
            } catch(e) { alert('Ошибка'); }
        }
        async function loadSpamWords() {
            const container = document.getElementById('spam-words-list');
            if (!container) return;
            container.innerHTML = '<p>Загрузка...</p>';
            try {
                const res = await fetch('/api/admin/spam_words');
                const data = await res.json();
                if (Object.keys(data).length === 0) {
                    container.innerHTML = '<p style="color:gray;">Список пуст.</p>';
                    return;
                }
                let html = '';
                for (const [board, words] of Object.entries(data)) {
                    if (words.length === 0) continue;
                    const title = board === 'all' ? '🌍 Глобально' : `/${board}/`;
                    html += `
                    <div style="background:var(--bg-input); border:1px solid var(--border-input); border-radius:4px; padding:10px;">
                        <h4 style="margin-top:0; color:var(--text-secondary); border-bottom:1px solid var(--border-separator); padding-bottom:5px;">${title}</h4>
                        <div style="display:flex; flex-wrap:wrap; gap:5px;">
                    `;
                    words.forEach(word => {
                        html += `
                            <span style="background:var(--bg-hover); padding:2px 8px; border-radius:15px; border:1px solid var(--border-input); display:flex; align-items:center; gap:5px;">
                                ${word}
                                <button onclick="removeSpamWord('${board}', '${word}')" style="background:none; border:none; color:red; cursor:pointer; font-weight:bold; padding:0; line-height:1;">&times;</button>
                            </span>
                        `;
                    });
                    html += `</div></div>`;
                }
                container.innerHTML = html || '<p>Слов нет.</p>';
            } catch(e) {
                console.error(e);
                container.innerHTML = '<p style="color:red;">Ошибка загрузки.</p>';
            }
        }
        async function removeSpamWord(board, word) {
            if(!confirm(`Удалить слово "${word}" из ${board}?`)) return;
            try {
                await fetch('/api/admin/remove_spam_word', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ board_id: board, word: word })
                });
                loadSpamWords();
            } catch(e) { alert('Ошибка'); }
        }
        async function loadGraphs() {
            const ctx = document.getElementById('activityChart');
            if (!ctx) return;
            
            // Уничтожаем старый экземпляр
            if (activityChartInstance) {
                activityChartInstance.destroy();
                activityChartInstance = null;
            }

            try {
                const res = await fetch('/api/admin/activity_stats');
                const data = await res.json();
                const history = data.history; 
                
                activityChartInstance = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: Object.keys(history),
                        datasets: [{
                            label: 'Постов в день',
                            data: Object.values(history),
                            borderColor: '#3182ce',
                            backgroundColor: 'rgba(49, 130, 206, 0.2)',
                            fill: true,
                            tension: 0.3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true, grid: { color: '#333' } },
                            x: { grid: { display: false } }
                        }
                    }
                });
            } catch (e) { console.error("Graph error", e); }
        }
        async function loadStats() {
            if (!document.getElementById('dashboard').classList.contains('active')) return;
            try {
                const res = await fetch('/api/admin/stats');
                const data = await res.json();
                
                // Основное
                document.getElementById('stat-posts').textContent = data.total_posts;
                document.getElementById('stat-threads').textContent = data.total_threads;
                document.getElementById('stat-online').textContent = data.active_connections;
                
                // Очереди
                if (data.queues) {
                    document.getElementById('q-mirror').textContent = data.queues.mirror;
                    document.getElementById('q-mod').textContent = data.queues.mod;
                    document.getElementById('q-notif').textContent = data.queues.notif;
                    document.getElementById('q-import').textContent = data.queues.import;
                    
                    // Обновление счетчика симуляции
                    const simEl = document.getElementById('q-import-sim');
                    if(simEl) simEl.textContent = data.queues.import_sim || 0;
                }

                const list = document.getElementById('top-boards-list');
                list.innerHTML = data.top_boards.map(b => `<li><b>/${b.board}/</b> — ${b.count} постов</li>`).join('');
            } catch (e) { console.error(e); }
        }
        async function updateServerHealth() {
            if (!document.getElementById('dashboard').classList.contains('active')) return;
            try {
                const res = await fetch('/api/admin/system_health');
                const data = await res.json();
                const updateCircle = (id, value, color) => {
                    const el = document.getElementById(id);
                    if(!el) return;
                    el.textContent = Math.round(value) + '%';
                    el.style.background = `radial-gradient(closest-side, var(--bg-input) 79%, transparent 80% 100%), conic-gradient(${color} ${value}%, var(--border-input) 0)`;
                    el.style.color = value > 90 ? 'var(--action-danger)' : 'var(--text-primary)';
                };
                updateCircle('health-cpu', data.cpu, '#3498db');
                updateCircle('health-ram', data.ram, '#9b59b6');
                updateCircle('health-disk', data.disk, '#e67e22');
            } catch(e) {}
        }
        async function loadLogs() {
            if (!document.getElementById('logs').classList.contains('active')) return;
            try {
                const res = await fetch('/api/admin/logs');
                const logs = await res.json();
                const consoleDiv = document.getElementById('log-console');
                const isAtBottom = consoleDiv.scrollHeight - consoleDiv.scrollTop === consoleDiv.clientHeight;

                consoleDiv.innerHTML = logs.map(l => `<div class="log-entry">${l}</div>`).join('');
                
                // Если это первая загрузка или скролл был внизу — мотаем вниз
                if (!consoleDiv.dataset.loaded || isAtBottom) {
                    consoleDiv.scrollTop = consoleDiv.scrollHeight;
                    consoleDiv.dataset.loaded = "true";
                }
            } catch (e) {}
        }
        // === ФУНКЦИИ ЖАЛОБ (REPORTS) ===
        async function loadReports() {
            const container = document.getElementById('reports-list');
            if (!container) return;
            container.innerHTML = '<p style="padding: 20px; text-align: center;">Загрузка...</p>';
            try {
                const res = await fetch('/api/admin/reports');
                const reports = await res.json();
                if (reports.length === 0) {
                    container.innerHTML = '<div style="padding:20px; text-align:center; color:green; font-size: 1.2em;">🎉 Жалоб нет! Все чисто.</div>';
                    return;
                }
                container.innerHTML = reports.map(r => {
                    const text = r.content && r.content.text ? r.content.text.substring(0, 300) : '[Медиа/Пусто]';
                    const postLink = r.board_id ? `/${r.board_id}/res/${r.post_num}.html#post-${r.post_num}` : '#';
                    const dateStr = new Date(r.created_at * 1000).toLocaleString();
                    return `
                    <div class="report-card" style="background: var(--bg-input); border: 1px solid var(--action-danger); border-left-width: 5px; padding: 15px; border-radius: 4px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                        <div style="display:flex; justify-content:space-between; margin-bottom:10px; border-bottom: 1px solid var(--border-separator); padding-bottom: 5px;">
                            <strong style="color: var(--action-danger); font-size: 1.1em;">${r.category}</strong>
                            <span style="color: var(--text-secondary); font-size: 0.9em;">${dateStr}</span>
                        </div>
                        <div style="margin-bottom: 10px; padding: 10px; background: var(--bg-hover); border-radius: 4px; font-family: monospace; font-size: 0.95em;">
                            <div style="margin-bottom: 5px;">
                                <b>Пост #${r.post_num}</b> в /${r.board_id}/ 
                                (<a href="${postLink}" target="_blank">Перейти к посту</a>)
                            </div>
                            <div style="opacity: 0.8; max-height: 100px; overflow-y: auto;">${text}</div>
                        </div>
                        <div style="margin-bottom: 15px;">
                            <b>Причина:</b> <span style="color: var(--text-primary);">${r.reason}</span>
                        </div>
                        <div class="report-actions" style="display:flex; gap: 10px; flex-wrap: wrap; justify-content: flex-end;">
                            <button class="btn btn-secondary" onclick="AdminAction.dismissReport(${r.id})">✅ Отклонить</button>
                            <button class="btn btn-secondary" onclick="AdminAction.deleteAndResolve(${r.post_num}, ${r.id})" style="color: orange; border-color: orange;">🗑 Удалить пост</button>
                            <button class="btn btn-primary" onclick="AdminAction.banAndResolve(${r.post_num}, ${r.id})" style="background-color: #d32f2f; border-color: #d32f2f;">🔨 Бан + Удалить</button>
                        </div>
                    </div>`;
                }).join('');
            } catch (e) {
                console.error(e);
                container.innerHTML = '<p style="color:red; text-align:center;">Ошибка загрузки жалоб.</p>';
            }
        }
        async function forceNeuro(mode) {
            const boardInput = document.getElementById('neuro-board-input');
            const streamSelect = document.getElementById('neuro-stream-select');
            const board = boardInput ? boardInput.value.trim() : 'b';
            const stream = streamSelect ? streamSelect.value : 'ru';
            const log = document.getElementById('neuro-log');
            if (!board) { alert("Укажите доску!"); return; }
            log.innerHTML = `⏳ Думаю над постом в /${board}/ [${stream.toUpperCase()}] (${mode})...\n` + log.innerHTML;
            try {
                const res = await fetch('/api/admin/force_neuro', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ 
                        board_id: board, 
                        mode: mode,
                        stream: stream 
                    })
                });
                const data = await res.json();
                if (data.status === 'ok') {
                    log.innerHTML = `<span style="color: #00ff00;">✅ ${data.log}</span>\n----------------\n` + log.innerHTML;
                } else {
                    log.innerHTML = `<span style="color: red;">❌ Ошибка: ${data.log || data.detail}</span>\n` + log.innerHTML;
                }
            } catch(e) {
                log.innerHTML = `<span style="color: red;">❌ Ошибка сети: ${e}</span>\n` + log.innerHTML;
            }
        } 
        const AdminAction = {
            async dismissReport(id) {
                await fetch('/api/admin/resolve_report', {
                    method: 'POST', headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ report_id: id, action: 'dismiss' })
                });
                loadReports(); 
            },
            async deleteAndResolve(postNum, reportId) {
                if(!confirm('Удалить пост?')) return;
                const res = await fetch('/api/admin/delete_post', {
                    method: 'POST', headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ post_num: postNum })
                });
                if (res.ok) {
                    await fetch('/api/admin/resolve_report', {
                        method: 'POST', headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({ report_id: reportId, action: 'resolved' })
                    });
                    loadReports();
                } else {
                    alert('Ошибка удаления поста');
                }
            },
            async banAndResolve(postNum, reportId) {
                if(!confirm('ВНИМАНИЕ: Забанить автора и удалить пост?')) return;
                const res = await fetch('/api/admin/ban_user', {
                    method: 'POST', headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ post_num: postNum })
                });
                if (res.ok) {
                    await fetch('/api/admin/resolve_report', {
                        method: 'POST', headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({ report_id: reportId, action: 'resolved' })
                    });
                    loadReports();
                } else {
                    alert('Ошибка бана');
                }
            }
        };

        async function loadModQueue() { 
            const grid = document.getElementById('mod-queue-grid');
            grid.innerHTML = '<p>Загрузка...</p>';
            try {
                const res = await fetch('/api/admin/mod_queue');
                const items = await res.json();
                grid.innerHTML = '';
                
                if (items.length === 0) {
                    grid.innerHTML = '<p style="color:green;">✅ Чисто! Нейронка спокойна.</p>';
                    return;
                }

                items.forEach(item => {
                    const card = document.createElement('div');
                    card.style.cssText = 'background: #252525; border: 1px solid #ff4444; border-radius: 6px; padding: 10px; position:relative;';
                    
                    // Красная подсветка причины
                    const badgeColor = item.score > 0.9 ? '#ff0000' : '#ff8800';
                    
                    let mediaHtml = '';
                    if (item.thumb_url) {
                        // Добавляем no-referrer, чтобы админ видел картинку с зеркала
                        mediaHtml = `<a href="/${item.board_id}/res/${item.post_num}.html" target="_blank"><img src="${item.thumb_url}" referrerpolicy="no-referrer" style="max-width:100%; max-height:200px; border-radius:4px; display:block; margin: 0 auto;"></a>`;
                    }

                    card.innerHTML = `
                        <div style="position:absolute; top:5px; right:5px; background:${badgeColor}; color:white; padding:2px 6px; border-radius:4px; font-weight:bold; font-size:12px;">
                            ${item.reason} (${Math.round(item.score*100)}%)
                        </div>
                        <div style="margin-bottom:10px;">
                            <b>/${item.board_id}/ #${item.post_num}</b><br>
                            <small style="color:#aaa;">ID: ${item.author_id}</small>
                        </div>
                        <div style="margin-bottom:10px; min-height:100px; background:#000; display:flex; align-items:center; justify-content:center;">
                            ${mediaHtml || '<span style="color:#555">Без медиа</span>'}
                        </div>
                        <div style="font-size:0.9em; margin-bottom:10px; max-height:60px; overflow-y:auto; background:#333; padding:5px;">
                            ${window.formatTextGlobal(item.content.text) || '<i>(Нет текста)</i>'}
                        </div>
                        <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:5px;">
                            <button class="btn btn-secondary" onclick="decideMod(${item.id}, ${item.post_num}, 'ignore')">Простить</button>
                            <button class="btn btn-primary" onclick="decideMod(${item.id}, ${item.post_num}, 'delete')" style="background:#e67e22;">Удалить</button>
                            <button class="btn btn-primary" onclick="decideMod(${item.id}, ${item.post_num}, 'ban')" style="background:#c0392b;">БАН + DEL</button>
                        </div>
                    `;
                    grid.appendChild(card);
                });
            } catch (e) {
                grid.innerHTML = '<p style="color:red">Ошибка загрузки</p>';
            }
        }

        async function decideMod(queueId, postNum, action) {
            if (!confirm('Подтвердить действие?')) return;
            try {
                await fetch('/api/admin/mod_decision', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ queue_id: queueId, post_num: postNum, action: action })
                });
                // Удаляем карточку визуально
                loadModQueue();
            } catch (e) {
                alert('Ошибка');
            }
        }
        async function loadBoardsList() {
            const div = document.getElementById('admin-boards-list');
            div.innerHTML = '<p style="padding:20px; text-align:center;">Загрузка...</p>';
            
            try {
                const res = await fetch('/api/admin/boards');
                const boards = await res.json();
                
                // Стили для таблицы
                const tableStyle = `
                    width: 100%; 
                    border-collapse: collapse; 
                    font-size: 0.9em; 
                    background: var(--bg-input); 
                    border-radius: 8px; 
                    overflow: hidden;
                `;
                const thStyle = `
                    text-align: left; 
                    padding: 12px 15px; 
                    background: var(--bg-hover); 
                    color: var(--text-secondary);
                    border-bottom: 2px solid var(--border-input);
                `;
                const tdStyle = `
                    padding: 12px 15px; 
                    border-bottom: 1px solid var(--border-input);
                    vertical-align: middle;
                `;

                let html = `<table style="${tableStyle}">`;
                html += `
                    <thead>
                        <tr>
                            <th style="${thStyle}">ID</th>
                            <th style="${thStyle}">Название</th>
                            <th style="${thStyle}">Владелец</th>
                            <th style="${thStyle}">Статус</th>
                            <th style="${thStyle}; text-align: right;">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                `;

                boards.forEach(b => {
                    const isSystem = b.owner_id === 0;
                    const status = b.is_approved 
                        ? '<span style="color:#2ecc71; font-weight:bold;">Active</span>' 
                        : '<span style="color:#f39c12; font-weight:bold;">На проверке</span>';
                    
                    const owner = isSystem 
                        ? '<span style="opacity:0.5; font-weight:bold;">SYSTEM</span>' 
                        : `<a href="#" onclick="alert('User ID: ${b.owner_id}')" style="color:var(--accent-link);">User #${b.owner_id}</a>`;

                    // КНОПКИ ДЕЙСТВИЙ
                    let actions = '';

                    // 1. Кнопка одобрения (только если не одобрено)
                    if (!b.is_approved) {
                        actions += `<button onclick="approveBoard('${b.board_id}')" class="btn btn-primary btn-small" style="margin-right:5px; padding: 4px 8px;" title="Одобрить">✅</button>`;
                    }

                    // 2. Кнопка удаления (ТОЛЬКО ДЛЯ ПОЛЬЗОВАТЕЛЬСКИХ ДОСОК)
                    if (!isSystem) {
                        actions += `<button onclick="deleteBoard('${b.board_id}')" class="btn btn-secondary btn-small" style="color:red; border-color:red; padding: 4px 8px;" title="Удалить">🗑</button>`;
                    } else {
                        // Пустышка или иконка замка для системных
                        actions += `<span style="opacity:0.3; cursor:not-allowed;" title="Системная доска">🔒</span>`;
                    }

                    html += `
                        <tr>
                            <td style="${tdStyle}; font-family:monospace; font-weight:bold; color:var(--accent-primary);">/${b.board_id}/</td>
                            <td style="${tdStyle}">${b.name}</td>
                            <td style="${tdStyle}">${owner}</td>
                            <td style="${tdStyle}">${status}</td>
                            <td style="${tdStyle}; text-align: right;">${actions}</td>
                        </tr>
                    `;
                });

                html += '</tbody></table>';
                div.innerHTML = html;

            } catch(e) { 
                console.error(e);
                div.innerHTML = '<p style="color:red; padding:20px;">Ошибка загрузки списка досок.</p>'; 
            }
        }
        async function approveBoard(id) {
