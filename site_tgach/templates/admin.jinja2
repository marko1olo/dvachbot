<!DOCTYPE html>
<html lang="{{ request.state.lang or 'ru' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ТГАЧ :: Центр Управления</title>
    <link rel="stylesheet" href="/static/css/style.css?v=2.9">
    <link rel="icon" href="/static/favicon.ico">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .scope-radio-group {
            display: flex;
            gap: 12px;
            margin-bottom: 15px;
            align-items: center;
            background: var(--bg-post);
            padding: 10px;
            border-radius: 6px;
            border: 1px solid var(--border-input);
        }
        .scope-btn {
            cursor: pointer;
            padding: 8px 16px;
            border: 1px solid var(--border-input);
            background: var(--bg-input);
            color: var(--text-secondary);
            border-radius: 6px;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
            font-weight: bold;
            font-size: 0.95em;
            user-select: none;
        }
        .scope-btn input { display: none; } /* Прячем стандартную точку */
        
        .scope-btn:hover {
            border-color: var(--text-secondary);
            color: var(--text-primary);
        }

        /* Активное состояние - Локальный (Синий) */
        .scope-btn:has(input[value="current"]:checked) {
            background: var(--accent-primary);
            color: #fff;
            border-color: var(--accent-primary);
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        /* Активное состояние - Глобальный (Красный/Опасный) */
        .scope-btn:has(input[value="global"]:checked) {
            background: #d32f2f; /* Красный */
            color: #fff;
            border-color: #d32f2f;
            box-shadow: 0 4px 10px rgba(211, 47, 47, 0.3);
            animation: pulse-danger 2s infinite;
        }

        @keyframes pulse-danger {
            0% { box-shadow: 0 0 0 0 rgba(211, 47, 47, 0.4); }
            70% { box-shadow: 0 0 0 6px rgba(211, 47, 47, 0); }
            100% { box-shadow: 0 0 0 0 rgba(211, 47, 47, 0); }
        }

        /* ИСПРАВЛЕНИЕ: Растягиваем фон на всю высоту, чтобы не было белой полосы снизу */
        html, body {
            min-height: 100vh;
            background-color: var(--bg-body, #212121);
            margin: 0;
        }
        /* Специфичные стили админки */
        .admin-layout {
            display: grid;
            grid-template-columns: 250px 1fr;
            gap: 20px;
            max-width: 1200px;
            margin: 20px auto;
        }
        /* Боковое меню */
        .admin-sidebar {
            background: var(--bg-post);
            border: 1px solid var(--border-primary);
            border-radius: 8px;
            padding: 15px;
            height: fit-content;
        }
        .admin-nav-btn {
            display: block;
            width: 100%;
            text-align: left;
            padding: 12px;
            margin-bottom: 5px;
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            border-radius: 4px;
            font-weight: bold;
            transition: all 0.2s;
        }
        .admin-nav-btn:hover { background: var(--bg-hover); color: var(--text-primary); }
        .admin-nav-btn.active { background: var(--accent-primary); color: var(--text-button); }
        /* Контент */
        .admin-content {
            background: var(--bg-post);
            border: 1px solid var(--border-primary);
            border-radius: 8px;
            padding: 25px;
            min-height: 500px;
        }
        .tab-pane { display: none; }
        .tab-pane.active { display: block; }
        /* Карточки статистики */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }
        .stat-card {
            background: var(--bg-input);
            border: 1px solid var(--border-input);
            padding: 20px;
            border-radius: 8px;
            text-align: center;
        }
        .stat-number { font-size: 2.5em; font-weight: bold; color: var(--accent-primary); display: block; }
        .stat-label { color: var(--text-secondary); font-size: 0.9em; text-transform: uppercase; }
        #inbox-badge {
            background: #ff4444;
            color: white;
            padding: 2px 6px;
            border-radius: 10px;
            font-size: 10px;
            margin-left: 5px;
            font-weight: bold;
            animation: pulse-red 2s infinite;
        }
        .feedback-card.unread {
            border-left: 4px solid #ff4444 !important;
            background: rgba(255, 68, 68, 0.05);
        }
        .log-console {
            background: #1e1e1e;
            color: #00ff00;
            font-family: monospace;
            padding: 15px;
            border-radius: 4px;
            height: 300px;
            overflow-y: auto;
            font-size: 0.85em;
            border: 1px solid #333;
            white-space: pre-wrap;
            word-break: break-all;
        }
        .log-entry { margin-bottom: 4px; border-bottom: 1px solid #333; padding-bottom: 2px; }
        /* Круговые диаграммы здоровья */
        .health-circle {
            width: 80px; height: 80px;
            border-radius: 50%;
            /* border: 4px solid var(--border-input); Убрали рамку для градиента */
            display: flex; align-items: center; justify-content: center;
            font-weight: bold; font-size: 1.2em;
            margin: 0 auto 10px;
            color: var(--text-primary);
            transition: background 0.5s ease;
        }
        @media (max-width: 768px) {
            .admin-layout { grid-template-columns: 1fr; }
        }
        .switch { position: relative; display: inline-block; width: 50px; height: 26px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; transition: .4s; border-radius: 34px; }
        .slider:before { position: absolute; content: ""; height: 20px; width: 20px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider { background-color: #dc3545; }
        input:focus + .slider { box-shadow: 0 0 1px #dc3545; }
        input:checked + .slider:before { transform: translateX(24px); }
    </style>
</head>
<body data-user-id="{{ request.state.user_hash }}" data-is-admin="{{ 'true' if session.user.is_admin else 'false' }}" data-site-mode="{{ site_mode }}">
    <div id="app-loader">
        <div class="loader-content">
            <img src="/static/logo.png" alt="TGACH" width="80" height="80">
            <div class="loader-spinner"></div>
        </div>
    </div>
    <script>
        (function() {
            try {
                var settings = JSON.parse(localStorage.getItem('user_settings') || '{}');
                var theme = settings.theme || localStorage.getItem('theme');
                if (!theme) {
                    if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) theme = 'dark';
                    else theme = 'light';
                    localStorage.setItem('theme', theme);
                }
                if (theme && theme !== 'light') document.body.classList.add('theme-' + theme);
                var fontStyle = settings.fontStyle || 'b';
                if (fontStyle === 'b') document.body.classList.add('font-style-b');
                var fontSize = settings.fontSize;
                if (!fontSize) {
                    if (window.innerWidth <= 768) fontSize = 'small';
                    else fontSize = 'medium';
                }
                document.body.classList.add('font-size-' + fontSize);
            } catch (e) { console.error(e); }
        })();
    </script>
    <header>
        <div class="board-nav">
            <a href="/">[На главную]</a>
        </div>
        <h1>👮‍♂️ Центр Управления ТГАЧ</h1>
    </header>
    <div class="admin-layout">
        <aside class="admin-sidebar">
            <!-- Видят ВСЕ сотрудники (Janitor+) -->
            <button class="admin-nav-btn active" onclick="openTab('dashboard')">📊 Дашборд</button>
            <button class="admin-nav-btn" onclick="openTab('reports')">🚨 Жалобы</button>
            <button class="admin-nav-btn" onclick="openTab('livefeed')">⚡ Live Feed</button>
            <button class="admin-nav-btn" onclick="openTab('graphs')">📈 Графики</button>
            <!-- Видят MOD, ADMIN, ROOT -->
            {% if user_role in ['mod', 'admin'] or is_root %}
                <button class="admin-nav-btn" onclick="openTab('moderation')">🔨 Модерация (Списки)</button>
                <button class="admin-nav-btn" onclick="openTab('mod_queue')">🛡️ Нейро-Щит</button>
                <button class="admin-nav-btn" onclick="openTab('bans')">⛔ Бан-лист</button>
                <button class="admin-nav-btn" onclick="openTab('firewall')">🧱 Файервол</button>
                <button class="admin-nav-btn" onclick="openTab('inspector')">🔍 Инспектор Постов</button>
                <button class="admin-nav-btn" onclick="openTab('user_inspector')">👤 Инспектор Юзеров</button>
                <button class="admin-nav-btn" onclick="openTab('inbox')">📬 Приемная <span id="inbox-badge" style="display:none;">New</span></button>
            {% endif %}
            <!-- Остальные кнопки без изменений... -->
            {% if user_role == 'admin' or is_root %}
                <button class="admin-nav-btn" onclick="openTab('boards')">📂 Доски</button>
                <button class="admin-nav-btn" onclick="openTab('banners')">🖼️ Баннеры</button>
                <button class="admin-nav-btn" onclick="openTab('spamfilter')">🛡️ Спам-фильтр</button>
                <button class="admin-nav-btn" onclick="openTab('import')">📥 Импорт Тредов</button>
                <button class="admin-nav-btn" onclick="openTab('requests')">📥 Заявки</button>
            {% endif %}
            {% if is_root %}
                <button class="admin-nav-btn" onclick="openTab('neuro')">🧠 Нейросеть</button>
                <button class="admin-nav-btn" onclick="openTab('settings')">⚙️ Система</button>
                <button class="admin-nav-btn" onclick="openTab('users')">👥 Пользователи (Роли)</button>
                <button class="admin-nav-btn" onclick="openTab('logs')">📜 Логи Системы</button>
                <button class="admin-nav-btn" onclick="openTab('fullstats')">📈 Полная Статистика</button>
            {% endif %}
        </aside>
        <section class="admin-content">
            <div id="dashboard" class="tab-pane active">
                <div class="server-health-panel" style="background: var(--bg-input); padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid var(--border-primary);">
                    <h3>🖥️ Состояние Сервера</h3>
                    <div style="display: flex; gap: 20px; justify-content: space-around; text-align: center;">
                        <div>
                            <div class="health-circle" id="health-cpu" style="border-color: #3498db;">0%</div>
                            <small>CPU</small>
                        </div>
                        <div>
                            <div class="health-circle" id="health-ram" style="border-color: #9b59b6;">0%</div>
                            <small>RAM</small>
                        </div>
                        <div>
                            <div class="health-circle" id="health-disk" style="border-color: #e67e22;">0%</div>
                            <small>HDD</small>
                        </div>
                    </div>
                </div>
                <h2>Статистика сайта</h2>
                <div class="stats-grid">
                    <div class="stat-card">
                        <span class="stat-number" id="stat-posts">-</span>
                        <span class="stat-label">Всего постов</span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-number" id="stat-threads">-</span>
                        <span class="stat-label">Живых тредов</span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-number" id="stat-online">-</span>
                        <span class="stat-label">WS Онлайн</span>
                    </div>
                </div>
                <h3>⚙️ Системные Очереди (Бэклог)</h3>
                <div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));">
                    <div class="stat-card" style="border-color: #f1c40f;">
                        <span class="stat-number" id="q-mirror" style="color: #f1c40f;">0</span>
                        <span class="stat-label">Зеркала</span>
                    </div>
                    <div class="stat-card" style="border-color: #e74c3c;">
                        <span class="stat-number" id="q-mod" style="color: #e74c3c;">0</span>
                        <span class="stat-label">Модерация</span>
                    </div>
                    <div class="stat-card" style="border-color: #3498db;">
                        <span class="stat-number" id="q-notif" style="color: #3498db;">0</span>
                        <span class="stat-label">Уведомления</span>
                    </div>
                    <div class="stat-card" style="border-color: #9b59b6;">
                        <span class="stat-number" id="q-import" style="color: #9b59b6;">0</span>
                        <span class="stat-label">Заявки (User)</span>
                    </div>
                    <div class="stat-card" style="border-color: #2ecc71;">
                        <span class="stat-number" id="q-import-sim" style="color: #2ecc71;">0</span>
                        <span class="stat-label">Симулятор (Очередь)</span>
                    </div>
                </div>
                <h3>Популярные доски</h3>
                <ul id="top-boards-list" style="list-style: none; padding: 0; margin-bottom: 20px;">
                </ul>
                <button class="btn btn-secondary" onclick="loadStats()" style="margin-bottom: 30px;">🔄 Обновить данные</button>
            </div>
            <div id="boards" class="tab-pane">
                <h2>📂 Управление Досками</h2>
                <div style="background:var(--bg-input); padding:15px; border-radius:4px; margin-bottom:20px; border: 1px solid var(--border-input);">
                    <h4>Создать новую доску</h4>
                    <form id="admin-create-board-form" style="display:flex; gap:10px; flex-wrap:wrap; align-items: center;">
                        <input type="text" name="board_id" placeholder="ID (напр: news)" required style="width:120px;" pattern="[a-z0-9]{2,10}">
                        <input type="text" name="name" placeholder="Название" required style="flex-grow:1;">
                        <input type="text" name="description" placeholder="Описание (опц.)" style="flex-grow:1;">
                        <button type="submit" class="btn btn-primary">Создать</button>
                    </form>
                </div>
                <div id="admin-boards-list">Загрузка списка...</div>
            </div>

            <div id="livefeed" class="tab-pane">
                <h2>⚡ Прямой эфир (Все доски)</h2>
                <div id="admin-live-feed" style="
                    height: 500px; overflow-y: auto; background: var(--bg-input); 
                    border: 1px solid var(--border-input); padding: 10px; font-family: monospace;">
                    <p style="color:gray">Ожидание постов...</p>
                </div>
            </div>

            <div id="graphs" class="tab-pane">
                <h2>📈 Активность (7 дней)</h2>
                <div style="background: white; padding: 20px; border-radius: 8px; position: relative; height: 400px;">
                    <canvas id="activityChart"></canvas>
                </div>
            </div>
            <div id="bans" class="tab-pane">
                <div class="card">
                    <h3>Черный список файлов</h3>
                    
                    <div style="background:#333; padding:10px; border-radius:4px; margin-bottom:15px; display:flex; gap:10px;">
                        <input type="text" id="manual-ban-id" placeholder="File ID (AgAC...)" style="flex-grow:1; padding:5px;">
                        <button class="btn btn-primary" style="background:#c0392b;" onclick="manualBanFile()">Забанить ID</button>
                    </div>

                    <button class="btn btn-secondary" onclick="loadBans()" style="margin-bottom:10px;">🔄 Обновить список</button>
                    
                    <table style="width:100%; border-collapse:collapse; font-size:0.9em;">
                        <thead>
                            <tr style="background:var(--bg-hover); text-align:left;">
                                <th style="padding:8px;">Превью</th>
                                <th style="padding:8px;">Тип / Хеш</th>
                                <th style="padding:8px;">Причина</th>
                                <th style="padding:8px;">Действие</th>
                            </tr>
                        </thead>
                        <tbody id="bans-table-body">
                            <!-- JS заполнит -->
                        </tbody>
                    </table>
                </div>
            </div>
            <div id="mod_queue" class="tab-pane">
                <div class="card">
                    <h3>🚨 Подозрительный контент (Очередь)</h3>
                    <p style="color:#aaa; font-size:0.9em;">Сюда попадает Гей-порно, Лоли и другой контент с пограничным скором.</p>
                    <button class="btn btn-secondary" onclick="loadModQueue()" style="margin-bottom:15px;">🔄 Обновить список</button>
                    
                    <div id="mod-queue-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 15px;">
                    </div>
                </div>
            </div>
            <div id="inspector" class="tab-pane">
                <h2>🔍 Инспектор Постов</h2>
                <p>Введите номер поста или ссылку на него, чтобы получить полную информацию об авторе и принять меры.</p>
                <div style="display: flex; gap: 10px; margin-bottom: 20px;">
                    <input type="text" id="inspect-input" placeholder="12345 или ссылка..." style="flex-grow: 1; padding: 10px; border-radius: 4px; border: 1px solid var(--border-input); background: var(--bg-input); color: var(--text-primary);">
                    <button class="btn btn-primary" onclick="inspectPost()">Найти</button>
                </div>
                    <div id="inspector-result" style="display: none;">
                        <!-- 1. Карточка Информации -->
                        <div style="background: var(--bg-input); border: 1px solid var(--border-primary); border-radius: 8px; padding: 20px; margin-bottom: 20px;">
                            <h3 style="margin-top: 0; color: var(--accent-primary);">📄 Данные поста #<span id="ins-num"></span></h3>
                            
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; font-size: 0.9em;">
                                <div>
                                    <p><strong>Доска:</strong> /<span id="ins-board"></span>/</p>
                                    <p><strong>User ID:</strong> <code id="ins-uid"></code></p>
                                    <p><strong>User Hash:</strong> <code id="ins-hash" style="color: orange;"></code></p>
                                </div>
                                <div>
                                    <p><strong>Дата:</strong> <span id="ins-date"></span></p>
                                    <p><strong>Всего постов:</strong> <span id="ins-total-posts"></span></p>
                                </div>
                            </div>

                            <div style="margin-top: 15px; padding: 10px; background: var(--bg-hover); border-radius: 4px; font-family: monospace; border: 1px solid var(--border-input);">
                                <strong style="color: var(--text-secondary);">Контент:</strong><br>
                                <span id="ins-text"></span>
                            </div>
                            
                            <div id="ins-files" style="margin-top: 10px; display: flex; gap: 10px;"></div>
                            <div id="ins-status-badges" style="margin-top: 10px;"></div>
                        </div>

                        <!-- 2. Панель Действий (Меры пресечения) -->
                        <div style="background: rgba(255, 0, 0, 0.05); border: 1px solid var(--action-danger); border-radius: 8px; padding: 20px; margin-bottom: 20px;">
                            <h3 style="margin-top: 0; color: var(--action-danger);">⚡ Меры пресечения</h3>
                            
                            <!-- Выбор области действия (Scope) -->
                            <div class="scope-radio-group">
                                <span style="font-weight: bold; margin-right: 5px;">Область:</span>
                                
                                <label class="scope-btn">
                                    <input type="radio" name="ins-scope" value="current" checked> 
                                    📍 Только /<span id="ins-scope-board">b</span>/
                                </label>
                                
                                <label class="scope-btn">
                                    <input type="radio" name="ins-scope" value="global"> 
                                    🌍 ВЕЗДЕ (Global)
                                </label>
                            </div>

                            <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end;">
                                <!-- Теневой бан -->
                                <div style="background: rgba(128,0,128,0.1); padding: 10px; border-radius: 4px; border: 1px solid purple;">
                                    <div style="margin-bottom: 5px; font-size: 0.9em; color: purple; font-weight: bold;">👻 Теневой Бан</div>
                                    <select id="ins-shadow-duration" style="padding: 5px;">
                                        <option value="3600">1 час</option>
                                        <option value="86400" selected>24 часа</option>
                                        <option value="604800">7 дней</option>
                                        <option value="2592000">30 дней</option>
                                        <option value="315360000">Навсегда</option>
                                    </select>
                                    <button class="btn btn-secondary" onclick="shadowBanUser()" style="border-color: purple; color: purple;">Применить</button>
                                </div>

                                <!-- Shadow Wipe -->
                                <div style="background: rgba(233, 30, 99, 0.1); padding: 10px; border-radius: 4px; border: 1px solid #e91e63;">
                                    <div style="margin-bottom: 5px; font-size: 0.9em; color: #e91e63; font-weight: bold;">🧛 Shadow Wipe</div>
                                    <button class="btn btn-secondary" onclick="shadowWipeUser()" style="border-color: #e91e63; color: #e91e63; width: 100%;">
                                        Скрыть все посты
                                    </button>
                                </div>

                                <div style="width: 1px; background: var(--border-primary); margin: 0 5px;"></div>

                                <!-- Хард бан -->
                                <button class="btn btn-secondary" onclick="hardBanUser()" style="border-color: red; color: red; height: fit-content; align-self: center;">
                                    🔨 Хард Бан + Удалить
                                </button>
                                
                                <button class="btn btn-primary" onclick="hardWipeUser()" style="background-color: red; border-color: red; height: fit-content; align-self: center;">
                                    ☢️ ПОЛНЫЙ ВАЙП
                                </button>
                            </div>
                        </div>

                        <!-- 3. История постов (Последние 30) -->
                        <div style="background: var(--bg-input); border: 1px solid var(--border-primary); border-radius: 8px; padding: 20px;">
                            <h3 style="margin-top: 0;">📜 История постов (Последние 30)</h3>
                            <div id="ins-history-list" style="max-height: 300px; overflow-y: auto; font-family: monospace; font-size: 0.85em;">
                                Загрузка...
                            </div>
                        </div>
                    </div>
                </div>
            <div id="user_inspector" class="tab-pane">
                <h2>👤 Досье на пользователя</h2>
                <p>Полная информация по ID: активность, баны, последние посты.</p>
                
                <div style="display: flex; gap: 10px; margin-bottom: 20px; background: var(--bg-input); padding: 15px; border-radius: 8px; border: 1px solid var(--border-input);">
                    <input type="number" id="inspect-user-id" placeholder="User ID (например: 12345)" style="flex-grow: 1; padding: 10px; border-radius: 4px; border: 1px solid var(--border-input); background: var(--bg-post); color: var(--text-primary);">
                    <button class="btn btn-primary" onclick="inspectUser()">🔍 Найти Досье</button>
                </div>

