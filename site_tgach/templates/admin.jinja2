        async function manualBanFile() {
            const fid = document.getElementById('manual-ban-id').value.trim();
            if(!fid) return;
            if(!confirm('Забанить этот файл навсегда?')) return;
            
            const res = await fetch('/api/admin/ban_single_file', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ file_id: fid })
            });
            const data = await res.json();
            if(data.status === 'ok') {
                alert('Забанено!');
                document.getElementById('manual-ban-id').value = '';
                loadBans();
