            if (scannerToggle) {
                scannerToggle.addEventListener('change', async (e) => {
                    const enabled = e.target.checked;
                    const intervalInput = document.getElementById('scanner-interval');
                    // Берем текущий интервал или дефолтный 66
                    const interval = intervalInput ? (parseInt(intervalInput.value) || 66) : 66;

                    try {
                        const res = await fetch('/api/admin/configure_scanner', {
                            method: 'POST',
                            headers: {'Content-Type': 'application/json'},
                            body: JSON.stringify({ enabled: enabled, interval: interval })
                        });
                        if(res.ok) showToast(`🕵️ Neuro-Scanner: ${enabled ? 'ON' : 'OFF'}`);
                        else { e.target.checked = !enabled; alert('Ошибка сервера'); }
                    } catch(err) { 
                        e.target.checked = !enabled; 
                        alert('Ошибка сети'); 
                    }
                });
            }
            // Обработчик формы спам-фильтра
            const spamForm = document.getElementById('add-spam-word-form');
            if (spamForm) {
                spamForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const btn = spamForm.querySelector('button');
                    btn.disabled = true;
                    const formData = new FormData(spamForm);
                    try {
                        const res = await fetch('/api/admin/add_spam_word', {
                            method: 'POST', headers: {'Content-Type': 'application/json'},
                            body: JSON.stringify(Object.fromEntries(formData))
                        });
                        if(res.ok) {
                            spamForm.querySelector('input[name="word"]').value = '';
                            loadSpamWords();
                        } else {
                            alert((await res.json()).detail || 'Ошибка');
                        }
                    } catch(e) { alert('Ошибка сети'); }
                    btn.disabled = false;
                });
            }
            // 2. Первая загрузка данных
            loadStats(); 
            updateServerHealth();
            // 3. Запуск таймеров (как ты просил: 20с и 60с)
            setInterval(loadLogs, 60000); 
            setInterval(updateServerHealth, 30000);
            setInterval(loadStats, 60000);
            if (typeof AdminManager !== 'undefined') {
                AdminManager.checkFeedbackCount();
                setInterval(() => AdminManager.checkFeedbackCount(), 60000);
            }
        });
        // === ИНСПЕКТОР ЮЗЕРОВ ===
        async function inspectUser() {
            const input = document.getElementById('inspect-user-id');
            const uid = input.value.trim();
            if (!uid) return alert('Введите ID пользователя');

            const container = document.getElementById('user-inspector-result');
            container.style.display = 'none';
            
            try {
                const res = await fetch('/api/admin/inspect_user', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ user_id: parseInt(uid) })
                });
                const resp = await res.json();
                
                if (!resp.found) {
                    alert('Пользователь не найден (нет записей в базе).');
                    return;
                }

                const data = resp.data;
                container.style.display = 'block';

                document.getElementById('ui-id').textContent = data.user_id;
                document.getElementById('ui-hash').textContent = data.user_hash || '-';
                document.getElementById('ui-role').textContent = (data.global_role || 'user').toUpperCase();
                document.getElementById('ui-seen').textContent = data.first_seen ? new Date(data.first_seen * 1000).toLocaleString() : '-';
                document.getElementById('ui-total').textContent = data.total_posts;

                const bansList = document.getElementById('ui-bans-list');
                if (data.active_bans.length === 0) {
                    bansList.innerHTML = '<li style="color:green">✅ Чист</li>';
                } else {
                    bansList.innerHTML = data.active_bans.map(b => 
                        `<li><b>${b.type}</b> на /${b.board_id}/ (до ${new Date(b.expires_at * 1000).toLocaleString()})</li>`
                    ).join('');
                }

                const boardsDiv = document.getElementById('ui-boards-list');
                boardsDiv.innerHTML = data.boards.map(b => 
                    `<span style="background:#333; color:white; padding:2px 6px; border-radius:4px; border:1px solid #555;">/${b.board_id}/: ${b.status}</span>`
                ).join('');

                const postsDiv = document.getElementById('ui-posts-list');
                postsDiv.innerHTML = data.last_posts.map(p => {
                    const txt = p.content.text ? p.content.text.substring(0, 100) : '[Медиа]';
                    return `<div style="border-bottom:1px solid #444; padding:2px 0;">[${new Date(p.timestamp*1000).toLocaleTimeString()}] /${p.board_id}/ #${p.id}: ${txt}</div>`;
                }).join('');

            } catch (e) {
                console.error(e);
                alert('Ошибка загрузки досье');
            }
        }

        // === LIVE FEED ИСТОРИЯ ===
        async function loadLiveFeedHistory() {
            const container = document.getElementById('admin-live-feed');
            if (!container || container.dataset.historyLoaded === "true") return;

            try {
                const res = await fetch('/api/admin/recent_posts');
                const posts = await res.json();
                
                // Рендерим историю (снизу вверх)
                const historyHtml = posts.reverse().map(p => 
                    `<div style="border-bottom:1px solid #333; padding:4px 0; font-family:monospace; font-size:12px; color:#aaa;">
                        [HISTORY ${p.time}] <span style="color:orange">/${p.board}/</span> 
                        #${p.id} (ID: ${p.author}): ${p.text}
                    </div>`
                ).join('');
                
                container.innerHTML = historyHtml + '<div style="text-align:center; color:#2ecc71; margin:10px 0; border-top:1px dashed #555;">⚡ LIVE STREAM CONNECTED ⚡</div>';
                container.scrollTop = container.scrollHeight;
                container.dataset.historyLoaded = "true";
            } catch(e) { console.error("History error", e); }
        }
    </script>
</body>
</html>