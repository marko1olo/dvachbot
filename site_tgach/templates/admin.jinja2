            if (!currentInspectorData) return;
            const scope = getScope();
            if (!confirm(`ХАРД БАН (${scope}) + Удалить этот пост?`)) return;
            
            const res = await fetch('/api/admin/ban_user', {
                method: 'POST', headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ 
                    post_num: currentInspectorData.post_num,
                    scope: scope
                })
            });
            if (res.ok) alert('Готово.');
