        async function deleteBoard(id) {
            if(!confirm('УДАЛИТЬ ДОСКУ И ВСЕ ЕЁ ТРЕДЫ?')) return;
            await fetch('/api/admin/board/delete', { method: 'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({board_id:id})});
