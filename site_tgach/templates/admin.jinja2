        async function shadowBanUser() {
            if (!currentInspectorData) return;
            const scope = getScope();
            const duration = parseInt(document.getElementById('ins-shadow-duration').value);
            
            if (!confirm(`Выдать ТЕНЕВОЙ БАН (${scope}) на выбранный срок?`)) return;
            
            const res = await fetch('/api/admin/shadow_ban', {
                method: 'POST', headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ 
                    post_num: currentInspectorData.post_num,
                    duration: duration,
                    scope: scope
                })
            });
            if (res.ok) alert(`Теневой бан выдан (${scope})`);
            else alert('Ошибка');
        }

        async function shadowWipeUser() {
            if (!currentInspectorData) return;
            const scope = getScope();
            if (!confirm(`SHADOW WIPE (${scope}): Скрыть все посты юзера?`)) return;

            const res = await fetch('/api/admin/shadow_wipe_user', {
                method: 'POST', headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ 
                    user_id: currentInspectorData.author_id,
                    scope: scope,
                    board_id: currentInspectorData.board_id
                })
            });
            const json = await res.json();
            alert(`Скрыто ${json.count} постов (${scope}).`);
        }

