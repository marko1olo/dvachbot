    {% macro pluralize(count, one, few, many) -%}
        {%- set count = count|int -%}
        {%- if count % 10 == 1 and count % 100 != 11 -%}
            {{ one }}
        {%- elif 2 <= count % 10 <= 4 and (count % 100 < 10 or count % 100 >= 20) -%}
            {{ few }}
        {%- else -%}
            {{ many }}
        {%- endif -%}
    {%- endmacro %}
    <!DOCTYPE html>
    <html lang="{{ request.state.lang or 'ru' }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{ board_info.name }} - {{ request.state.t('site_name') }}</title>
        <link rel="stylesheet" href="/static/css/style.css?v=8.88228">
        <link rel="icon" href="/static/favicon.ico">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, interactive-widget=resizes-content">
        <meta property="og:site_name" content="ТГАЧ">
        <meta property="og:type" content="website">
        <meta property="og:title" content="/{{ board_id }}/ — {{ board_info.name }}">
        <meta property="og:description" content="{{ board_info.description }}">
        <meta property="og:url" content="{{ request.url }}">
        <link rel="canonical" href="{{ request.state.canonical_url }}">
        <meta property="og:image" content="{{ meta_image }}">

        
        <meta name="twitter:card" content="summary">
        <meta name="twitter:title" content="/{{ board_id }}/ — {{ board_info.name }}">
        <meta name="twitter:description" content="{{ board_info.description }}">
        <meta name="twitter:image" content="{{ meta_image }}">

        <link rel="manifest" href="/static/manifest.json">
        <meta name="theme-color" content="#212121">
        <meta name="mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
        <link rel="apple-touch-icon" href="/static/icons/icon-192.png">
        <link rel="preconnect" href="https://api.telegram.org" crossorigin>
        <link rel="dns-prefetch" href="https://files.catbox.moe">
        <link rel="dns-prefetch" href="https://huggingface.co">
        <link rel="preconnect" href="https://huggingface.co" crossorigin>
        <link rel="canonical" href="{{ request.url._url.split('?')[0] }}">
        <style>
            .file-btn-icon { display: none; }
            .file-btn-text { display: inline; }
            @media (max-width: 768px) {
                .file-btn-text { display: none; }
                .file-btn-icon { display: inline; font-size: 1.2em; }
                /* Уменьшаем паддинги кнопки на мобиле */
                .file-input-label-mobile { padding: 8px 12px !important; }
            }
            #post-form.drag-over::after, #post-form-bottom.drag-over::after {
                content: "{{ request.state.t('drag_hint') }}" !important;
            }
            .post.hidden::after {
                content: "{{ request.state.t('post_hidden_hint') }}" !important;
            }
        </style>
    </head>
    <body class="{% if board_id == 'wh40k' %}theme-conan override-theme{% endif %}" 
        data-user-id="{{ request.state.user_hash }}" 
        data-current-board="{{ board_id }}" 
        data-site-mode="{{ site_mode }}" 
        data-is-admin="{{ 'true' if session.user and session.user.is_admin else 'false' }}" 
        data-user-role="{{ session.user.role if session.user else 'user' }}" 
        data-lockdown="{{ 'true' if request.state.is_lockdown else 'false' }}" 
        data-is-archived="{{ 'true' if is_archived else 'false' }}"
        data-skeleton="{{ 'true' if is_skeleton else 'false' }}">
        <div id="app-loader">
            <div class="loader-content">
                <img src="/static/logo.png" alt="TGACH" width="80" height="80">
                <div class="loader-spinner"></div>
            </div>
        </div>
        <script>
            (function() {
                try {
                    var settings = JSON.parse(localStorage.getItem('user_settings') || '{}');
                    var theme = settings.theme || localStorage.getItem('theme');
                    if (!theme) {
                        if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) theme = 'dark';
                        else theme = 'light';
                        localStorage.setItem('theme', theme);
                    }
                    if (theme && theme !== 'light') {
                        if (document.body) document.body.classList.add('theme-' + theme);
                        else document.addEventListener('DOMContentLoaded', function() {
                            document.body.classList.add('theme-' + theme);
                        });
                    }
                    var fontStyle = settings.fontStyle || 'b';
                    if (fontStyle === 'b') document.body.classList.add('font-style-b');
                    var fontSize = settings.fontSize;
                    if (!fontSize) {
                        if (window.innerWidth <= 768) fontSize = 'small';
                        else fontSize = 'medium';
                    }
                    document.body.classList.add('font-size-' + fontSize);
                } catch (e) { console.error(e); }
            })();
        </script>
    <header>
        <div class="board-nav-top">
            <a href="/overboard/" title="Все треды">/all/</a>

            {% for category in ['popular', 'bio', 'thematic', 'system'] %}
                {% set category_boards = [] %}
                {% for b_key, b_val in boards.items() %}
                    {% if b_val.category == category %}{% set _ = category_boards.append(b_key) %}{% endif %}
                {% endfor %}
                
                {% if category_boards %}
                    <span style="opacity:0.3; margin-left:8px;">[</span>
                    {% for b_key in category_boards %}
                        <a href="/{{ b_key }}/threads/" class="{% if b_key == board_id %}active{% endif %}" title="{{ boards[b_key].name }}">
                            {{ boards[b_key].name }}
                        </a>
                    {% endfor %}
                    <span style="opacity:0.3; margin-right:8px;">]</span>
                {% endif %}
            {% endfor %}
        </div>
        <div class="header-main-row">
            <div class="header-logo" style="display: flex; align-items: center; gap: 15px;">
                <h1>
                    <a href="/">ТГАЧ</a> 
                </h1>
                <span style="font-family: var(--font-headings); font-weight:bold; font-size: 1.2em; color: var(--text-secondary);">
                    {{ board_info.name }}
                </span>

                <form action="/search" method="get" class="search-form compact-search" style="margin-left: 10px;">
                    <input type="text" name="query" placeholder="Поиск..." value="{{ request.query_params.get('query', '') }}" style="padding: 4px 8px; font-size: 0.9em;">
                    <button type="submit" style="padding: 4px 8px;">🔍</button>
                </form>
            </div>
            <div class="header-group-right">
                <div class="user-actions">
                    {% if session.user and session.user.is_admin %}
                        <a href="/admin" class="header-btn admin-btn" title="Админ-панель">👮‍♂️</a>
                    {% endif %}
                    <a href="#" id="bottle-notification-btn" class="header-btn" style="display: none; position: relative;">
                        ✉️<span id="bottle-count"></span>
                    </a>
                    <a href="#" id="favourites-btn" class="header-btn" title="{{ request.state.t('fav_title') }}">⭐</a>
                    <button id="settings-btn" class="header-btn" title="{{ request.state.t('settings_btn_title') }}">⚙️</button>
                    <button id="theme-toggle" class="theme-toggle-btn" title="{{ request.state.t('theme_btn_title') }}">🌙</button>
                    {% if session.user %}
                        <a href="/auth/logout" class="logout-link">{{ request.state.t('logout_btn') }}</a>
                    {% else %}
                        <a href="/login" class="header-btn" title="{{ request.state.t('login_btn') }}">🔑</a>
                    {% endif %}
                </div>
            </div>
        </div>
        {% if board_info.banner_data and board_info.banner_data.img %}
            <div class="board-banner-container" style="text-align: center; margin-bottom: 5px; padding: 0 15px;">
                <a href="{{ board_info.banner_data.link or '#' }}" target="_blank">
                    <img src="{{ board_info.banner_data.img }}" style="max-width: 100%; max-height: 150px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.2);">
                </a>
            </div>
        {% endif %}
        <nav class="board-header-nav">
            <a href="/">[{{ request.state.t('nav_home') }}]</a>
            <span class="nav-sep">|</span>
            <a href="/{{ board_id }}/mode/">[{{ request.state.t('nav_mode_select') }}]</a>
            <div class="mobile-break"></div>
            <span class="nav-sep">|</span>
            <a href="/{{ board_id }}/threads/" class="active">[{{ request.state.t('nav_threads') }}]</a>
            <a href="/{{ board_id }}/chat/">[{{ request.state.t('nav_chat') }}]</a>
            <a href="/{{ board_id }}/catalog/">[{{ request.state.t('nav_catalog') }}]</a>
            {% if board_info.username %}
            <a href="https://t.me/{{ board_info.username.lstrip('@') }}" target="_blank" class="tg-link">[{{ request.state.t('nav_tg') }}]</a>
            {% endif %}
            <span class="nav-sep">|</span>
            <a href="#" class="gallery-trigger">[{{ request.state.t('nav_gallery') }}]</a>
        </nav>
    </header>
        <main>
            <div class="form-container">
                <h3 id="form-toggle-button" class="form-toggle-button">
                    {{ request.state.t('form_create_thread') }} <span class="form-toggle-arrow">[+]</span>
                </h3>
            </div>
            <form id="post-form" class="is-hidden-by-toggle">
                <input type="text" name="email" class="hp-field" autocomplete="off" tabindex="-1">
                <input type="text" name="username" class="name-field" autocomplete="off" tabindex="-1">
                <button type="button" id="tt-toggle-btn" title="Выбрать тип треда">⚙️</button>
                <div id="thread-type-selector" class="thread-type-selector">
                    <h4 style="margin: 0 0 10px 0; font-size: 1em; border-bottom: 1px solid var(--border-separator); padding-bottom: 5px;">Тип треда</h4>
                    <label class="tt-option">
                        <input type="radio" name="thread_type" value="default" checked>
                        <div>
                            <span class="tt-label">Обычный</span>
                            <span class="tt-desc">Текст и файлы</span>
                        </div>
                    </label>
                    <label class="tt-option">
                        <input type="radio" name="thread_type" value="image">
                        <div>
                            <span class="tt-label">Image Only</span>
                            <span class="tt-desc">Только картинки</span>
                        </div>
                    </label>
                    <label class="tt-option">
                        <input type="radio" name="thread_type" value="video">
                        <div>
                            <span class="tt-label">Video Only</span>
                            <span class="tt-desc">Только видео/WebM</span>
                        </div>
                    </label>
                    <label class="tt-option">
                        <input type="radio" name="thread_type" value="audio">
                        <div>
                            <span class="tt-label">Audio Only</span>
                            <span class="tt-desc">Только музыка/войсы</span>
                        </div>
                    </label>
                    <label class="tt-option">
                        <input type="radio" name="thread_type" value="media">
                        <div>
                            <span class="tt-label">Media Only</span>
                            <span class="tt-desc">Любой файл (No Text)</span>
                        </div>
                    </label>
                </div>
                <div class="form-fields">
                    <div class="format-buttons">
                        <button type="button" class="format-btn" data-tag="b" title="{{ request.state.t('form_btn_bold') }}"><b>B</b></button>
                        <button type="button" class="format-btn" data-tag="i" title="{{ request.state.t('form_btn_italic') }}"><i>I</i></button>
                        <button type="button" class="format-btn" data-tag="s" title="{{ request.state.t('form_btn_strike') }}"><s>S</s></button>
                        <button type="button" class="format-btn" data-tag="spoiler" title="{{ request.state.t('form_btn_spoiler') }}">Spoiler</button>
                        <span style="border-left: 1px solid var(--border-input); margin: 0 5px;"></span>
                        <button type="button" class="format-btn" data-tag="shake" title="{{ request.state.t('form_btn_shake') }}">😵</button>
                        <button type="button" class="format-btn" data-tag="rainbow" title="{{ request.state.t('form_btn_rainbow') }}">🌈</button>
                        <button type="button" class="format-btn" data-tag="blur" title="{{ request.state.t('form_btn_blur') }}">🌫️</button>
                        <button type="button" class="format-btn" data-tag="glitch" title="{{ request.state.t('form_btn_glitch') }}">👾</button>
                        <button type="button" class="format-btn" id="help-tags-btn" title="{{ request.state.t('form_btn_help') }}">❓</button>
                    </div>
                    <textarea id="post-text" name="text" placeholder="{{ request.state.t('form_text_placeholder') }}" rows="4" cols="50"></textarea>
                    <div id="file-preview-container" class="file-preview-container"></div>
                </div>
                <div class="form-controls">
                    <label for="file-input" class="btn btn-secondary file-input-label-mobile">
                        <span class="file-btn-text">{{ request.state.t('btn_attach') }}</span>
                        <span class="file-btn-icon">📎</span>
                    </label>
                    <label class="picrandom-container" title="{{ request.state.t('rand_pic_hint') }}">
                        <input type="checkbox" name="picrandom" value="true">
                        <span class="picrandom-icon">🎲</span>
                        <span class="picrandom-label">{{ request.state.t('btn_rand') }}</span>
                    </label>
                    <button id="record-audio-btn" class="btn btn-secondary" title="{{ request.state.t('btn_voice') }}">🎤</button>
                    <input type="file" id="file-input" name="images" accept="image/*,video/mp4,video/webm" multiple style="display: none;">
                    <input type="hidden" name="board_id" value="{{ board_id }}">
                    <input type="hidden" name="post_mode" value="new_thread">
                    <div class="loading-indicator-inline">{{ request.state.t('sending') }}</div>
                    <button type="submit" class="btn btn-primary">{{ request.state.t('btn_submit_thread') }}</button>
                </div>
                <div id="upload-progress-container" class="upload-progress-container">
                    <div id="upload-progress-bar" class="upload-progress-bar"></div>
                    <span id="upload-progress-text" class="upload-progress-text"></span>
                </div>
            </form>
            <hr>
            <div class="sort-options">
                <span>{{ request.state.t('sort_label') }}</span>
                <a href="?sort=bump" class="btn btn-secondary {% if current_sort == 'bump' %}active{% endif %}">{{ request.state.t('sort_bump') }}</a>
                <a href="?sort=new" class="btn btn-secondary {% if current_sort == 'new' %}active{% endif %}">{{ request.state.t('sort_new') }}</a>
                <a href="/{{ board_id }}/catalog/" class="btn btn-secondary" style="float: right;">{{ request.state.t('catalog_link') }}</a>
                <button id="media-mode-btn" class="btn btn-secondary" style="background-color: #000; color: #fff; border: 1px solid #333;">{{ request.state.t('btn_board_gallery') }}</button>
            </div>
            <div class="thread-list">
                {% if posts %}
                    {% for post in posts %}
                    <div class="thread-container {% if post.is_archived %}archived-thread-preview{% endif %} {% if post.is_pinned %}pinned-thread{% endif %}" id="thread-{{ post.id }}" {% if post.is_endless %}data-endless="true"{% endif %}>
                    <div class="post {% if post.content.sage %}is-sage{% endif %}" id="post-{{ post.id }}" data-reports="{{ post.report_count }}">
                            <div class="post-header">
                                <canvas class="identicon" data-userid="{{ post.author_id }}" width="20" height="20"></canvas>
                                <span class="post-author" {% if session.user and session.user.is_admin %}data-nick="{{ post.author_id | nick_from_hash }}"{% endif %}>
                                    {% if session.user and session.user.is_admin %}
                                        {{ post.author_id | nick_from_hash }}
                                    {% elif board_id == 'wh40k' %}
                                        {{ ['Гвардеец', 'Служитель', 'Сервитор', 'Еретик', 'Хаосит', 'Техножрец', 'Инквизитор'] | random }}
                                    {% else %}
                                        {{ request.state.t('anon_name') }}
                                    {% endif %}
                                </span>
                                <span>
                                    <a href="/{{ board_id }}/res/{{ post.id }}.html" class="post-num-link" target="_blank" rel="noopener noreferrer">#{{ post.id }}</a>
                                    {% if post.is_pinned %} <span title="Закреплен" style="color:var(--accent-primary); margin-left:5px;">📌</span> {% endif %}
                                    {% if post.is_endless %} <span title="Бесконечный тред" style="color:var(--accent-link); margin-left:5px;">🔄</span> {% endif %}
                                    {% if post.is_op %}<span class="you-marker">{{ request.state.t('you_marker') }}</span>{% endif %}
                                    {% if post.thread_type == 'image' %}<span class="thread-type-badge tt-image" style="font-size:0.7em;">🖼️ IMG</span>{% endif %}
                                    {% if post.thread_type == 'video' %}<span class="thread-type-badge tt-video" style="font-size:0.7em;">🎬 VID</span>{% endif %}
                                    {% if post.thread_type == 'audio' %}<span class="thread-type-badge tt-audio" style="font-size:0.7em;">🎵 AUD</span>{% endif %}
                                    {% if post.thread_type == 'media' %}<span class="thread-type-badge tt-media" style="font-size:0.7em;">📁 MEDIA</span>{% endif %}
                                    {% if post.is_op %}<span class="you-marker">{{ request.state.t('you_marker') }}</span>{% endif %}
                                </span>
                                <span>{% if post.is_archived %} 🔒{% endif %}</span>
                                <span class="ts-recalc" data-ts="{{ post.timestamp }}">{{ post.timestamp | format_timestamp }}</span>
                                {% if post.content.sage %}<span class="sage-indicator">SAGE</span>{% endif %}
                                <a href="#" class="favourite-btn" data-thread-id="{{ post.id }}" title="{{ request.state.t('fav_title') }}">⭐</a>
                                <a href="/{{ board_id }}/res/{{ post.id }}.html" class="post-header-link">{{ request.state.t('btn_goto_thread', '[ В тред ]') }}</a>
                                <div class="post-actions">
                                    <button class="action-menu-trigger" 
                                        data-post-num="{{ post.id }}" 
                                        data-board-id="{{ board_id }}" 
                                        data-thread-id="{{ post.id }}"
                                        data-author-id="{{ post.author_id }}"
                                        {% if post.is_op %}data-is-op="true"{% endif %}>
                                        ▶
                                    </button>
                                </div>
                            </div>
                        <div class="post-content">
                                {% if post.content.files %}
                                    <div class="post-files-container post-gallery">
                                        {% for file in post.content.files %}
                                            {% if file.type in ['image', 'photo', 'sticker', 'video_note', 'video', 'gif', 'animation'] %}
                                                {% if file.type == 'image' or file.type == 'photo' or file.type == 'sticker' %}
                                                    <a href="{{ file.original_url }}" class="file-thumb" data-filename="{{ file.filename }}" data-file-id="{{ file.original_file_id }}" data-type="image">
                                                        {% if file.blurhash %}
                                                            <canvas class="blurhash-canvas" data-hash="{{ file.blurhash }}" width="32" height="32"></canvas>
                                                        {% endif %}
                                                        <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" 
                                                            data-src="{{ file.thumbnail_url or file.original_url }}" 
                                                            class="post-image lazy-load{% if post.content.is_censored %} blurred-media{% endif %}" alt="img" referrerpolicy="no-referrer" onload="this.classList.add('loaded')">
                                                            {% if file.dupe_count is defined and file.dupe_count > 1 %}<div class="bayan-text">{{ file.dupe_count | bayan_label(request.state.lang) }}</div>{% endif %}
                                                    </a>
                                                {% elif file.type == 'sticker' %}
                                                    <div class="sticker-wrapper" style="display:inline-block; vertical-align:bottom;">
                                                        {% if file.filename.endswith('.webm') %}
                                                            <a href="{{ file.original_url }}" class="gallery-trigger" data-type="video" data-filename="{{ file.filename }}" data-file-id="{{ file.original_file_id }}">
                                                                <video class="post-sticker{% if post.content.is_censored %} blurred-media{% endif %}" src="{{ file.original_url }}" autoplay loop muted playsinline webkit-playsinline referrerpolicy="no-referrer"></video>
                                                            </a>
                                                        {% else %}
                                                            <a href="{{ file.original_url }}" class="gallery-trigger" data-type="image" data-filename="{{ file.filename }}" data-file-id="{{ file.original_file_id }}">
                                                                <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" 
                                                                    data-src="{{ file.thumbnail_url or file.original_url }}" 
                                                                    class="post-sticker lazy-load{% if post.content.is_censored %} blurred-media{% endif %}" 
                                                                    referrerpolicy="no-referrer">
                                                            </a>
                                                        {% endif %}
                                                    </div>
                                                {% elif file.type == 'video_note' %}
                                                    <video class="post-video video-note lazy-load{% if post.content.is_censored %} blurred-media{% endif %}" 
                                                           data-src="{{ file.original_url }}" 
                                                           poster="{{ file.thumbnail_url }}"
                                                           autoplay 
                                                           loop 
                                                           muted 
                                                           playsinline 
                                                           onclick="event.preventDefault(); event.stopPropagation(); this.paused ? this.play() : this.pause();"
                                                           style="border-radius: 50%; object-fit: cover;" 
                                                           referrerpolicy="no-referrer">
                                                    </video>
                                                {% elif file.type == 'video' or file.type == 'gif' or file.type == 'animation' %}
                                                    <div class="file-thumb lazy-media-wrapper" 
                                                        data-src="{{ file.original_url }}" 
                                                        data-filename="{{ file.filename }}"
                                                        data-type="{{ 'gif' if file.type in ['gif', 'animation'] else 'video' }}">
                                                        {% if file.blurhash %}
                                                            <canvas class="blurhash-canvas" data-hash="{{ file.blurhash }}" width="32" height="32"></canvas>
                                                        {% endif %}
                                                        <video class="post-image lazy-load{% if post.content.is_censored %} blurred-media{% endif %}" 
                                                               preload="metadata" 
                                                               muted 
                                                               playsinline
                                                               loop
                                                               data-src="{{ file.original_url }}"
                                                               {% if file.thumbnail_url %}poster="{{ file.thumbnail_url }}"{% endif %}
                                                               style="object-fit: cover; width: 100%; height: 100%; background: #000;">
                                                        </video>
                                                        <span class="lazy-badge">{{ 'GIF' if file.type in ['gif', 'animation'] else 'VIDEO' }}</span>
                                                    </div>
                                                {% endif %}
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                    <div class="post-audios-container">
                                        {% for file in post.content.files %}
                                            {% if file.type in ['audio', 'voice', 'document'] %}
                                                {% if file.type == 'audio' or file.type == 'voice' %}
                                                    {% set unique_id = 'audio-' ~ post.id ~ '-' ~ loop.index %}
                                                    <div class="custom-audio-player" id="player-{{ unique_id }}" data-src="{{ file.original_url }}">
                                                        <audio id="{{ unique_id }}" preload="none"><source src="{{ file.original_url }}" type="{{ file.mime_type or 'audio/mpeg' }}"></audio>
                                                        <button class="cap-play-btn" data-target="{{ unique_id }}" type="button">▶</button>
                                                        <div class="cap-body">
                                                            <div class="cap-title" title="{{ file.filename }}">
                                                                {% set lower_name = file.filename.lower() %}
                                                                {% set clean_name = file.filename.rsplit('.', 1)[0] | replace('_', ' ') %}
                                                                {% if lower_name.startswith('voice_') or 'audiorecord' in lower_name %}
                                                                    <span class="cap-artist">{{ request.state.t('audio_voice_label') or 'Голосовое сообщение' }}</span>
                                                                    <span class="cap-track">{{ clean_name }}</span>
                                                                {% else %}
                                                                    {% set name_parts = clean_name.split(' - ') %}
                                                                    {% if name_parts|length >= 2 %}
                                                                        <span class="cap-artist">{{ name_parts[0] }}</span>
                                                                        <span class="cap-track">{{ name_parts[1:]|join(' - ') }}</span>
                                                                    {% else %}
                                                                        <span class="cap-artist">{{ request.state.t('audio_random_artists') | random }}</span>
                                                                        <span class="cap-track">{{ clean_name if clean_name.lower() != 'audio' else request.state.t('audio_random_tracks') | random }}</span>
                                                                    {% endif %}
                                                                {% endif %}
                                                            </div>
                                                            <div class="cap-controls-row">
                                                                <div class="cap-info"><span class="cap-time">00:00</span></div>
                                                                <div class="cap-progress-container" data-target="{{ unique_id }}"><div class="cap-wave-base"></div><div class="cap-wave-progress"></div></div>
                                                                <div class="cap-info"><button class="cap-speed-btn" data-target="{{ unique_id }}" type="button">1x</button></div>
                                                                <a href="{{ file.original_url }}" download="{{ file.filename }}" class="cap-download-btn">⬇</a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                {% elif file.type == 'document' %}
                                                    <div style="margin-top:5px;">
                                                        <a href="{{ file.original_url }}" target="_blank" class="file-document-link">📄 {{ file.filename }}</a>
                                                    </div>
                                                {% endif %}
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            <div class="post-text-content">
                                <div class="post-text">{{ post.content.text | format_post_text | safe }}</div>
                            </div>
                        </div>
                        </div>
                    {% if post.reply_count > 0 or post.latest_replies %}
                        <div class="thread-stats-container" style="margin: 2px 0 2px 20px; font-size: 0.85em; color: var(--text-muted);">
                            {{ request.state.t('stat_thread_details', replies=post.reply_count, anons=post.anon_count) }}
                            <a href="/{{ board_id }}/res/{{ post.id }}.html" style="color: inherit; text-decoration: underline;">{{ request.state.t('btn_open_thread') }}</a>
                        </div>
                        <div class="latest-replies-container">
                            {% for reply in post.latest_replies %}
                            <div class="post reply-preview" id="post-{{ reply.id }}" data-reports="{{ reply.report_count }}">
                                <div class="post-header">
                                    <canvas class="identicon" data-userid="{{ reply.author_id }}" width="20" height="20"></canvas>
                                    <span class="post-author" {% if session.user and session.user.is_admin %}data-nick="{{ reply.author_id | nick_from_hash }}"{% endif %}>
                                        {% if session.user and session.user.is_admin %}
                                            {{ reply.author_id | nick_from_hash }}
                                        {% elif board_id == 'wh40k' %}
                                            {{ ['Гвардеец', 'Служитель', 'Сервитор', 'Еретик', 'Хаосит', 'Техножрец', 'Инквизитор'] | random }}
                                        {% else %}
                                            {{ request.state.t('anon_name') }}
                                        {% endif %}
                                    </span>
                                    <span>
                                        <a href="/{{ board_id }}/res/{{ post.id }}.html#post-{{ reply.id }}" class="post-num-link" data-post-num="{{ reply.id }}">#{{ reply.id }}</a>
                                    </span>
                                    <span class="ts-recalc" data-ts="{{ reply.timestamp }}">{{ reply.timestamp | format_timestamp }}</span>
                                    <div class="post-actions">
                                        <button class="action-menu-trigger" 
                                            data-post-num="{{ reply.id }}" 
                                            data-board-id="{{ board_id }}" 
                                            data-thread-id="{{ post.id }}"
                                            data-author-id="{{ reply.author_id }}">
                                            ▶
                                        </button>
                                    </div>
                                </div>
                                <div class="post-content">
                                    {% if reply.content.files %}
                                        <div class="post-files-container post-gallery">
                                            {% for file in reply.content.files %}
                                                {% if file.type in ['image', 'photo', 'sticker', 'video_note', 'video', 'gif', 'animation'] %}
                                                    {% if file.type == 'image' or file.type == 'photo' or file.type == 'sticker' %}
                                                        <a href="{{ file.original_url }}" class="file-thumb" data-filename="{{ file.filename }}" data-file-id="{{ file.original_file_id }}" data-type="image">
                                                            {% if file.blurhash %}
                                                                <canvas class="blurhash-canvas" data-hash="{{ file.blurhash }}" width="32" height="32"></canvas>
                                                            {% endif %}
                                                            <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" 
                                                                data-src="{{ file.thumbnail_url or file.original_url }}" 
                                                                class="post-image lazy-load{% if reply.content.is_censored %} blurred-media{% endif %}" alt="img" referrerpolicy="no-referrer" onload="this.classList.add('loaded')">
                                                            {% if file.dupe_count is defined and file.dupe_count > 1 %}<div class="bayan-text">{{ file.dupe_count | bayan_label(request.state.lang) }}</div>{% endif %}
                                                        </a>
                                                    {% elif file.type == 'sticker' %}
                                                        <div class="sticker-wrapper" style="display:inline-block; vertical-align:bottom;">
                                                            {% if file.filename.endswith('.webm') %}
                                                                <a href="{{ file.original_url }}" class="gallery-trigger" data-type="video" data-filename="{{ file.filename }}" data-file-id="{{ file.original_file_id }}">
                                                                    <video class="post-sticker{% if reply.content.is_censored %} blurred-media{% endif %}" src="{{ file.original_url }}" autoplay loop muted playsinline webkit-playsinline referrerpolicy="no-referrer"></video>
                                                                </a>
                                                            {% else %}
                                                                <a href="{{ file.original_url }}" class="gallery-trigger" data-type="image" data-filename="{{ file.filename }}" data-file-id="{{ file.original_file_id }}">
                                                                    <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" 
                                                                        data-src="{{ file.thumbnail_url or file.original_url }}" 
                                                                        class="post-sticker lazy-load{% if reply.content.is_censored %} blurred-media{% endif %}" 
                                                                        referrerpolicy="no-referrer">
                                                                </a>
                                                            {% endif %}
                                                        </div>
                                                    {% elif file.type == 'video_note' %}
                                                        <div class="lazy-media-wrapper is-note" data-src="{{ file.original_url }}" data-filename="{{ file.filename }}" data-type="note">
                                                            <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" 
                                                                data-src="{{ file.thumbnail_url or '/static/img/vid.png' }}" 
                                                                class="post-video video-note lazy-load{% if reply.content.is_censored %} blurred-media{% endif %}" 
                                                                style="border-radius: 50%;" referrerpolicy="no-referrer">
                                                        </div>
                                                    {% elif file.type == 'video' or file.type == 'gif' or file.type == 'animation' %}
                                                        <div class="file-thumb lazy-media-wrapper" 
                                                            data-src="{{ file.original_url }}" 
                                                            data-filename="{{ file.filename }}"
                                                            data-type="{{ 'gif' if file.type in ['gif', 'animation'] else 'video' }}">
                                                            {% if file.blurhash %}
                                                                <canvas class="blurhash-canvas" data-hash="{{ file.blurhash }}" width="32" height="32"></canvas>
                                                            {% endif %}
                                                            <video class="post-image lazy-load{% if reply.content.is_censored %} blurred-media{% endif %}" 
                                                                   preload="metadata" 
                                                                   muted 
                                                                   playsinline
                                                                   loop
                                                                   data-src="{{ file.original_url }}"
                                                                   {% if file.thumbnail_url %}poster="{{ file.thumbnail_url }}"{% endif %}
                                                                   style="object-fit: cover; width: 100%; height: 100%; background: #000;">
                                                            </video>
                                                            <span class="lazy-badge">{{ 'GIF' if file.type in ['gif', 'animation'] else 'VIDEO' }}</span>
                                                        </div>
                                                    {% endif %}
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                        <div class="post-audios-container">
                                            {% for file in reply.content.files %}
                                                {% if file.type in ['audio', 'voice', 'document'] %}
                                                    {% if file.type == 'audio' or file.type == 'voice' %}
                                                        {% set unique_id = 'audio-' ~ reply.id ~ '-' ~ loop.index %}
                                                        <div class="custom-audio-player" id="player-{{ unique_id }}" data-src="{{ file.original_url }}">
                                                            <audio id="{{ unique_id }}" preload="none"><source src="{{ file.original_url }}" type="{{ file.mime_type or 'audio/mpeg' }}"></audio>
                                                            <button class="cap-play-btn" data-target="{{ unique_id }}" type="button">▶</button>
                                                            <div class="cap-body">
                                                                <div class="cap-title" title="{{ file.filename }}">
                                                                    {% set lower_name = file.filename.lower() %}
                                                                    {% set clean_name = file.filename.rsplit('.', 1)[0] | replace('_', ' ') %}
                                                                    {% if lower_name.startswith('voice_') or 'audiorecord' in lower_name %}
                                                                        <span class="cap-artist">{{ request.state.t('audio_voice_label') or 'Голосовое сообщение' }}</span>
                                                                        <span class="cap-track">{{ clean_name }}</span>
                                                                    {% else %}
                                                                        {% set name_parts = clean_name.split(' - ') %}
                                                                        {% if name_parts|length >= 2 %}
                                                                            <span class="cap-artist">{{ name_parts[0] }}</span>
                                                                            <span class="cap-track">{{ name_parts[1:]|join(' - ') }}</span>
                                                                        {% else %}
                                                                            <span class="cap-artist">{{ request.state.t('audio_random_artists') | random }}</span>
                                                                            <span class="cap-track">{{ clean_name if clean_name.lower() != 'audio' else request.state.t('audio_random_tracks') | random }}</span>
                                                                        {% endif %}
                                                                    {% endif %}
                                                                </div>
                                                                <div class="cap-controls-row">
                                                                    <div class="cap-info"><span class="cap-time">00:00</span></div>
                                                                    <div class="cap-progress-container" data-target="{{ unique_id }}"><div class="cap-wave-base"></div><div class="cap-wave-progress"></div></div>
                                                                    <div class="cap-info"><button class="cap-speed-btn" data-target="{{ unique_id }}" type="button">1x</button></div>
                                                                    <a href="{{ file.original_url }}" download="{{ file.filename }}" class="cap-download-btn">⬇</a>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    {% elif file.type == 'document' %}
                                                        <div style="margin-top:5px;">
                                                            <a href="{{ file.original_url }}" target="_blank" class="file-document-link">📄 {{ file.filename }}</a>
                                                        </div>
                                                    {% endif %}
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                    <div class="post-text-content">
                                        <div class="post-text">{{ reply.content.text | format_post_text | safe }}</div>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </div>
                    <hr class="thread-separator">
                    {% endfor %}
                {% else %}
                    <div id="no-threads-msg" class="no-threads-msg" style="text-align: center; padding: 40px; color: var(--text-secondary); {% if is_skeleton %}display: none;{% endif %}">
                        <div style="font-size: 3em; margin-bottom: 10px;">📭</div>
                        <p style="font-size: 1.1em; margin-bottom: 20px;">{{ request.state.t('no_threads') }}</p>
                        <button class="btn btn-secondary" onclick="window.location.reload()">
                            🔄 {{ request.state.t('nav_refresh') }}
                        </button>
                    </div>
                {% endif %}
            </div>
            <div id="threads-loading-indicator" style="display: {% if is_skeleton %}block{% else %}none{% endif %}; text-align: center; padding: 20px; color: var(--text-secondary);">
                {{ request.state.t('loading') }}
            </div>
