                    <button type="button" onclick="document.getElementById('settings-modal').style.display='none'; document.getElementById('modal-overlay').style.display='none';" class="btn btn-primary modal-close-btn" style="width: 100%;">{{ request.state.t('btn_close') }}</button>
                </div>
            </form>
        </div>
        <div class="modal" id="help-modal" style="display: none; max-width: 600px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; border-bottom: 1px solid var(--border-primary); padding-bottom: 10px;">
                <h3 style="margin: 0; border: none;">{{ request.state.t('help_title') }}</h3>
                <button class="btn btn-secondary modal-close-btn" style="font-size: 1.5em; line-height: 1; padding: 0 8px;">&times;</button>
            </div>
            <div class="help-content" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div>
                    <h4 style="margin-top: 0; color: var(--text-secondary);">{{ request.state.t('help_basics') }}</h4>
                    <ul style="list-style: none; padding: 0; line-height: 1.8;">
                        <li><code>[b]Текст[/b]</code> → <b>Жирный</b></li>
                        <li><code>[i]Текст[/i]</code> → <i>Курсив</i></li>
                        <li><code>[s]Текст[/s]</code> → <s>Зачеркнутый</s></li>
                        <li><code>||Текст||</code> → <span class="spoiler">Спойлер</span></li>
                    </ul>
                </div>
                <div>
                    <h4 style="margin-top: 0; color: var(--text-secondary);">{{ request.state.t('help_effects') }}</h4>
                    <ul style="list-style: none; padding: 0; line-height: 1.8;">
                        <li><code>[shake]...[/shake]</code> → <span class="effect-shake">Тряска</span></li>
                        <li><code>[rainbow]...[/rainbow]</code> → <span class="effect-rainbow">Наримашка</span></li>
                        <li><code>[blur]...[/blur]</code> → <span class="effect-blur">Сосал?</span> (Наведи)</li>
                        <li><code>[glitch]...[/glitch]</code> → <span class="effect-glitch" data-text="Глитч">Глитч</span></li>
                    </ul>
                </div>
            </div>
            <div style="margin-top: 15px; text-align: right;">
                <button class="btn btn-secondary modal-close-btn" style="font-size: 1.5em; line-height: 1; padding: 0 8px;">&times;</button>
            </div>
        </div>
        <div class="modal" id="stealth-edit-modal" style="display: none; max-width: 500px;">
            <h3>🥷 Скрытое редактирование</h3>
            <form id="stealth-edit-form">
                <input type="hidden" name="post_num" id="se-post-num">
                <div class="form-group">
                    <label>Текст (HTML разрешен):</label>
                    <textarea name="text" id="se-text" rows="6" style="width: 100%; font-family: monospace;"></textarea>
                </div>
                <div class="form-group">
                    <label>Удалить файлы (отметьте):</label>
                    <div id="se-current-files" style="display: flex; gap: 5px; flex-wrap: wrap; padding: 5px; background: var(--bg-input); border-radius: 4px;">
                        <span style="color: var(--text-secondary); font-size: 0.9em;">Нет файлов</span>
                    </div>
                </div>
                <div class="form-group" style="margin-top: 10px;">
                    <label>Добавить новые файлы:</label>
                    <input type="file" name="new_images" multiple>
                </div>
                <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 15px;">
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('stealth-edit-modal').style.display='none'; document.getElementById('modal-overlay').style.display='none';">Отмена</button>
                    <button type="submit" class="btn btn-primary" style="background-color: #e67e22; border-color: #d35400;">Сохранить тихо</button>
                </div>
            </form>
        </div>
        <div class="modal" id="filters-modal" style="display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-separator); margin-bottom: 15px; padding-bottom: 10px;">
                <h3 style="margin: 0; border: none; padding: 0;">🛡️ Фильтрация контента</h3>
                <button type="button" onclick="saveFiltersAndBack()" class="btn btn-secondary" style="font-size: 1.5em; line-height: 1; padding: 0 8px;">&times;</button>
            </div>
            <div class="form-group">
                <label for="filter-words-input">Скрывать посты со словами:</label>
                <textarea id="filter-words-input" rows="8" placeholder="Одно слово или /регекс/ на строку..." style="width: 100%; font-family: monospace; font-size: 13px; padding: 10px;"></textarea>
                <small style="display: block; margin-top: 10px; color: var(--text-secondary); line-height: 1.4;">
                    <b>Anti-Wipe:</b> Включен по умолчанию. Автоматически скрывает CAPS LOCK, длинные бессмысленные строки и спам повторами.
                </small>
            </div>
            <div style="margin-top: 20px;">
                <button type="button" onclick="saveFiltersAndBack()" class="btn btn-primary" style="width: 100%; font-weight: bold;">Сохранить и вернуться</button>
            </div>
        </div>
        <div id="loading-indicator" class="loading-indicator">Отправка...</div>
            <div id="global-action-menu">
                <a href="#" class="menu-btn" data-action="reply">{{ request.state.t('action_reply') }}</a>
                <a href="#" class="menu-btn" data-action="view-thread" id="menu-view-thread-btn">{{ request.state.t('action_view_thread') }}</a>
                <a href="#" class="menu-btn" data-action="copy-link">{{ request.state.t('action_copy_link') }}</a>
                <a href="#" class="menu-btn" data-action="bottle">{{ request.state.t('action_bottle') }}</a>
                <a href="#" class="menu-btn" data-action="speak">{{ request.state.t('action_speak') }}</a>
                <a href="#" class="menu-btn" data-action="report">{{ request.state.t('action_report') }}</a>
                <a href="#" class="menu-btn" data-action="hide">{{ request.state.t('action_hide') }}</a>
                <!-- Уровень 1: Дворник (Janitor) -->
                <div class="role-janitor" style="display:none; border-top:1px solid #ccc; margin-top:5px;">
                    <a href="#" class="menu-btn admin-action" data-action="delete">🗑 {{ request.state.t('action_delete') }}</a>
                    <a href="#" class="menu-btn admin-action" data-action="delete-after" style="color: orange;">✂️ {{ request.state.t('action_delete_after') }}</a>
                </div>        
                <!-- Уровень 2: Модератор (Mod) -->
                <div class="role-mod" style="display:none;">
                    <a href="#" class="menu-btn admin-action" data-action="move" style="color: #0984e3;">🚚 Перенести тред</a>
                    <a href="#" class="menu-btn admin-action" data-action="ban">🔨 {{ request.state.t('action_ban') }}</a>
                    <a href="#" class="menu-btn admin-action" data-action="img-ban" style="color: #c0392b; font-weight: bold;">⛔ Бан Картинки</a>
                    <a href="#" class="menu-btn admin-action" data-action="shadow" style="color: purple;">👻 {{ request.state.t('action_shadow') }}</a>
                    <a href="#" class="menu-btn admin-action" data-action="pin" style="color: green;">📌 Pin/Unpin</a>
                    <a href="#" class="menu-btn admin-action" data-action="endless" style="color: blue;">🔄 Endless</a>
                </div>
                <!-- Уровень 3: Админ (Admin) -->
                <div class="role-admin" style="display:none;">
                    <a href="#" class="menu-btn admin-action" data-action="wipe" style="color: red; font-weight: bold;">☢️ {{ request.state.t('action_wipe') }}</a>
                    <a href="#" class="menu-btn admin-action" data-action="stealth" style="color: #e67e22;">🥷 Stealth Edit</a>
                </div>
            </div>
            <script src="/static/js/main.js?v=8.88228" defer></script>
        </body>
        <div class="modal" id="bottle-modal" style="display: none;">
            <h3>Отправить записку анону</h3>
            <form id="bottle-form">
                <div class="form-group">
                    <textarea id="bottle-text" name="text" rows="4" maxlength="280" placeholder="Ваше анонимное послание (до 280 символов)..." required></textarea>
                    <small style="color: var(--text-secondary);">Это увидят только вы и получатель. Сообщение самоуничтожится после прочтения.</small>
                </div>
                <input type="hidden" id="bottle-post-num-input" name="post_num">
                <div style="display: flex; justify-content: flex-end; gap: 10px;">
                    <button type="button" id="bottle-cancel-btn" class="btn btn-secondary">Отмена</button>
                    <button type="submit" class="btn btn-primary">Отправить</button>
                </div>
            </form>
        </div>
        <div class="modal" id="shadow-ban-modal" style="display: none;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; border-bottom: 1px solid var(--border-primary); padding-bottom: 10px;">
                <h3 style="margin: 0; border: none;">{{ request.state.t('shadow_modal_title') }}</h3>
                <button onclick="document.getElementById('shadow-ban-modal').style.display='none'; document.getElementById('modal-overlay').style.display='none';" class="btn btn-secondary" style="font-size: 1.5em; line-height: 1; padding: 0 8px;">&times;</button>
            </div>
            <form id="shadow-ban-form">
                <input type="hidden" id="shadow-ban-post-num" name="post_num">
                <div class="form-group">
                    <label>{{ request.state.t('shadow_duration') }}</label>
                    <select name="duration" class="form-control">
                        <option value="3600">1 час</option>
                        <option value="86400" selected>24 часа</option>
                        <option value="604800">7 дней</option>
                        <option value="2592000">30 дней</option>
                    </select>
                </div>
                <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px;">
                    <button type="button" onclick="document.getElementById('shadow-ban-modal').style.display='none'; document.getElementById('modal-overlay').style.display='none';" class="btn btn-secondary">{{ request.state.t('btn_cancel') }}</button>
                    <button type="submit" class="btn btn-primary" style="background-color: purple; border-color: purple;">{{ request.state.t('btn_shadow_confirm') }}</button>
                </div>
            </form>
        </div>
