            <a href="/about/">{{ request.state.t('nav_about') }}</a>
            <a href="/faq/">{{ request.state.t('nav_faq') }}</a>
            <a href="/useful/">{{ request.state.t('nav_useful') }}</a>
            <a href="/tags/">{{ request.state.t('nav_tags') }}</a> 
