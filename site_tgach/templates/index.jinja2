<!DOCTYPE html>
<html lang="{{ request.state.lang or 'ru' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ТГАЧ - Веб-интерфейс</title>
    <link rel="stylesheet" href="/static/css/style.css?v=8.88">
    <link rel="icon" href="/static/favicon.ico">
    <meta property="og:site_name" content="ТГАЧ">
    <meta property="og:type" content="website">
    <meta property="og:title" content="ТГАЧ — Новая имиджборда">
    <meta property="og:description" content="{{ request.state.t('meta_description') }}">
    <meta property="og:url" content="{{ request.url }}">
    <link rel="canonical" href="{{ request.state.canonical_url }}">
    <meta property="og:image" content="{{ meta_image }}">
    
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="ТГАЧ — Новая имиджборда">
    <meta name="twitter:description" content="{{ request.state.t('meta_description') }}">
    <meta name="twitter:image" content="{{ meta_image }}">

    <link rel="manifest" href="/static/manifest.json">
    <meta name="theme-color" content="#212121">
