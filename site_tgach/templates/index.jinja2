            <a href="/archive/" style="color: var(--accent-primary); font-weight: bold;">{{ request.state.t('nav_archive_link') }}</a>
        </nav>
        <p>{{ request.state.t('footer_text') }}</p>
    </footer>
    <div class="modal-overlay" id="modal-overlay" style="display: none;"></div>
    <div class="modal" id="quick-reply-modal" style="display: none;"></div>
