<body class="page-index" {% if session.user %}data-user-id="{{ request.state.user_hash }}"{% endif %} data-site-mode="{{ site_mode }}"data-lockdown="{{ 'true' if request.state.is_lockdown else 'false' }}">
    <script>
        (function() {
            try {
                var settings = JSON.parse(localStorage.getItem('user_settings') || '{}');
                var theme = settings.theme || localStorage.getItem('theme');
                if (!theme) {
                    if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) theme = 'dark';
                    else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) theme = 'light';
                    else theme = Math.random() < 0.5 ? 'dark' : 'light';
                    localStorage.setItem('theme', theme);
                }
                if (theme && theme !== 'light') {
                    if (document.body) document.body.classList.add('theme-' + theme);
                    else document.addEventListener('DOMContentLoaded', function() {
                        document.body.classList.add('theme-' + theme);
                    });
                }
                var fontStyle = settings.fontStyle || 'b';
                if (fontStyle === 'b') document.body.classList.add('font-style-b');
                var fontSize = settings.fontSize;
                if (!fontSize) {
                    if (window.innerWidth <= 768) fontSize = 'small';
                    else fontSize = 'medium';
                }
                document.body.classList.add('font-size-' + fontSize);
            } catch (e) { console.error(e); }
        })();
    </script>
    <header>
        <div class="board-nav-top">
            <a href="/overboard/" title="Все треды">/all/</a>

            {% for category in ['popular', 'bio', 'thematic', 'system'] %}
                {% set category_boards = [] %}
                {% for b_key, b_val in boards.items() %}
                    {% if b_val.category == category %}{% set _ = category_boards.append(b_key) %}{% endif %}
                {% endfor %}
                
                {% if category_boards %}
                    <span style="opacity:0.3; margin-left:8px;">[</span>
                    {% for b_key in category_boards %}
                        <a href="/{{ b_key }}/threads/" class="{% if b_key == board_id %}active{% endif %}" title="{{ boards[b_key].name }}">
                            {{ boards[b_key].name }}
                        </a>
                    {% endfor %}
                    <span style="opacity:0.3; margin-right:8px;">]</span>
                {% endif %}
            {% endfor %}
        </div>
        <div class="header-main-row">
            <div class="header-logo">
                <h1>
                    <a href="/">ТГАЧ</a> 
                </h1>
            </div>
            <div class="header-group-right">
                <div class="user-actions">
                    {% if session.user and session.user.is_admin %}
                        <a href="/admin" class="header-btn admin-btn" title="Админ-панель">👮‍♂️</a>
                    {% endif %}
                    <a href="#" id="bottle-notification-btn" class="header-btn" style="display: none; position: relative;">✉️<span id="bottle-count"></span></a>
                    <a href="#" id="favourites-btn" class="header-btn" title="{{ request.state.t('fav_title') }}">⭐</a>
                    <button id="settings-btn" class="header-btn" title="{{ request.state.t('settings_btn_title') }}">⚙️</button>
                    <button id="theme-toggle" class="theme-toggle-btn" title="{{ request.state.t('theme_btn_title') }}">🌙</button>
                    {% if session.user %}
                        <a href="/auth/logout" class="logout-link">{{ request.state.t('logout_btn') }}</a>
                    {% else %}
                        <a href="/login" class="header-btn" title="{{ request.state.t('login_btn') }}">🔑</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </header>
    <main>
        <div class="view-controls" style="display:flex; justify-content:space-between; align-items:center;">
            <div style="font-weight:bold; color:var(--text-secondary);">Каталог досок</div>
            <button id="style-switch-btn" class="btn btn-secondary" style="min-width:120px;">
                <span id="style-name-display">Плитка</span>
            </button>
        </div>
        <div class="board-card-grid">
            <div class="board-group-header" style="margin-top:0;">Навигация</div>
            <a href="/overboard/" class="board-card" data-color1="#34495e" data-color2="#2c3e50">
                <div class="board-card-content">
                    <span class="board-card-name">/all/</span>
                    <p class="board-card-description">Оверборд (Все треды)</p>
                </div>
            </a>
            <a href="/tv/random" class="board-card" data-color1="#2d3436" data-color2="#00cec9">
                <div class="board-card-content">
                    <span class="board-card-name">/webm/</span>
                    <p class="board-card-description">WebM Рандом-TV</p>
                </div>
            </a>
            <a href="/img/random" class="board-card" data-color1="#8e44ad" data-color2="#9b59b6">
                <div class="board-card-content">
                    <span class="board-card-name">/img/</span>
                    <p class="board-card-description">Рандом Пикчи</p>
                </div>
            </a>
            {% for category_key, category_name in [
                ('popular', 'Основа'),
                ('bio', 'Биопроблемы'),
                ('thematic', 'Тематика'),
                ('system', 'Система')
            ] %}
                <div class="board-group-header">{{ category_name }}</div>
                {% for board_id, board_info in boards.items() %}
                    {% if board_info.category == category_key %}
                        <a href="/{{ board_id }}/" 
                           class="board-card" 
                           data-board-id="{{ board_info.name }}"
                           data-color1="{{ board_info.color1 or '#4a4a4a' }}"
                           data-color2="{{ board_info.color2 or '#9b9b9b' }}">
                            <div class="board-card-content">
                                <span class="board-card-name">{{ board_info.name }}</span>
                                <!-- Безопасное получение описания: если словарь - берем ru, иначе выводим как есть -->
                                <p class="board-card-description">
                                    {{ board_info.description['ru'] if board_info.description is mapping else board_info.description }}
                                </p>
                            </div>
                        </a>
                    {% endif %}
                {% endfor %}
                
                {% if category_key == 'system' %}
                    <a href="/archive/chat/" class="board-card" data-color1="#2c3e50" data-color2="#bdc3c7">
                        <div class="board-card-content">
                            <span class="board-card-name">/arch_chat/</span>
                            <p class="board-card-description">Архив Чата</p>
                        </div>
                    </a>
                    <a href="/archive/threads/" class="board-card" data-color1="#2c3e50" data-color2="#7f8c8d">
                        <div class="board-card-content">
                            <span class="board-card-name">/arch_th/</span>
                            <p class="board-card-description">Архив Тредов</p>
                        </div>
                    </a>
                {% endif %}
            {% endfor %}
        </div>
    </main>
    <footer>
