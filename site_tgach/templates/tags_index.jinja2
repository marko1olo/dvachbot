<!DOCTYPE html>
<html lang="{{ request.state.lang or 'ru' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ meta_title }} — ТГАЧ</title>
    <link rel="stylesheet" href="/static/css/style.css?v=8.8">
    <link rel="icon" href="/static/favicon.ico">
    <meta name="description" content="{{ meta_description }}">
    
    <meta property="og:title" content="{{ meta_title }}">
    <meta property="og:description" content="{{ meta_description }}">
    <link rel="canonical" href="{{ request.state.canonical_url }}">
    
    <style>
        .tag-cloud-wrapper {
            background: var(--bg-post);
            padding: 40px 20px;
            border-radius: 12px;
            border: 1px solid var(--border-primary);
            box-shadow: var(--shadow-main);
            text-align: center;
            line-height: 2; /* Увеличил межстрочный интервал для облака */
        }

        .tag-item {
            display: inline-block;
            margin: 8px 15px;
            text-decoration: none;
            color: var(--accent-primary);
            transition: all 0.2s ease;
            white-space: nowrap;
            font-weight: 500;
        }

        .tag-item:hover {
            color: var(--accent-link);
            transform: scale(1.1);
            text-shadow: 0 0 10px var(--accent-highlight);
        }

        .tag-count {
            color: var(--text-secondary);
            font-size: 0.6em;
            font-weight: normal;
            vertical-align: super;
            margin-left: 2px;
            opacity: 0.7;
        }

        .tags-header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .tags-header h1 {
            border: none;
            font-size: 2.2em;
            margin-bottom: 10px;
        }
    </style>
</head>
<body class="page-tags">
    <header>
        <div class="board-nav-top">
            <a href="/">[ {{ request.state.t('nav_home') or 'На главную' }} ]</a>
        </div>
    </header>

    <main>
        <div class="tags-header">
            <h1>🏷️ {{ meta_title }}</h1>
            <p style="color: var(--text-secondary);">Поиск контента по категориям и тегам</p>
        </div>

        <div class="tag-cloud-wrapper">
            {% if tags %}
                {% for tag_name, count in tags %}
                    {# Расчет размера шрифта перенесен сюда, где доступна переменная count #}
                    <a href="/tags/{{ tag_name|replace(' ', '-') }}" 
                       class="tag-item" 
                       style="font-size: clamp(1rem, {{ 1.0 + (count / 200) }}rem, 2.5rem);">
                        #{{ tag_name }}<span class="tag-count">{{ count }}</span>
                    </a>
                {% endfor %}
            {% else %}
                <div style="padding: 40px; opacity: 0.5;">
                    {{ request.state.t('no_tags_found') or 'Теги еще не извлечены. Нужно больше постов!' }}
                </div>
            {% endif %}
        </div>
        
        <div style="margin-top: 40px; color: var(--text-secondary); font-size: 0.9em; text-align: center; max-width: 600px; margin-left: auto; margin-right: auto; line-height: 1.6;">
            {{ request.state.t('tags_footer_info') or 'Наше нейро-ядро автоматически анализирует каждое видео и изображение, присваивая им релевантные теги для удобной навигации по архиву.' }}
        </div>
    </main>

    <footer>
        <p>&copy; 2026 ТГАЧ. Все права защищены. <br> <small>Индексация тегов обновляется раз в 5 минут.</small></p>
    </footer>

    <script src="/static/js/main.js?v=2.0" defer></script>
</body>
</html>