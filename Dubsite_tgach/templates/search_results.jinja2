<!DOCTYPE html>
<html lang="{{ request.state.lang or 'ru' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Поиск: {{ query }} - {{ request.state.t('site_name') }}</title>
    <link rel="stylesheet" href="/static/css/style.css?v=2.9">
    <link rel="icon" href="/static/favicon.ico">
    <link rel="preconnect" href="https://api.telegram.org" crossorigin>
    <link rel="dns-prefetch" href="https://files.catbox.moe">
    <link rel="dns-prefetch" href="https://huggingface.co">
    <link rel="preconnect" href="https://huggingface.co" crossorigin>
</head>
<body {% if session.user %}data-user-id="{{ request.state.user_hash }}"{% endif %} data-site-mode="{{ site_mode }}">
    <script>
        (function() {
            try {
                var settings = JSON.parse(localStorage.getItem('user_settings') || '{}');
                // 1. ТЕМА
                var theme = settings.theme || localStorage.getItem('theme');
                if (!theme) {
                    if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) theme = 'dark';
                    else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) theme = 'light';
                    else theme = Math.random() < 0.5 ? 'dark' : 'light';
                    localStorage.setItem('theme', theme);
                }
                if (theme && theme !== 'light') document.body.classList.add('theme-' + theme);
                // 2. СТИЛЬ ШРИФТА (Roboto/Verdana)
                var fontStyle = settings.fontStyle || 'b';
                if (fontStyle === 'b') document.body.classList.add('font-style-b');
                // 3. РАЗМЕР ШРИФТА (АВТОМАТИЧЕСКИЙ ДЛЯ МОБИЛОК)
                var fontSize = settings.fontSize;
                if (!fontSize) {
                    // Если настройки нет, смотрим на ширину экрана прямо сейчас
                    if (window.innerWidth <= 768) fontSize = 'small';
                    else fontSize = 'medium';
                }
                document.body.classList.add('font-size-' + fontSize);
            } catch (e) { console.error(e); }
        })();
    </script>
    <header>
        <div class="header-group-left">
            <h1>
                <a href="/" style="text-decoration:none; color:inherit;">ТГАЧ</a> 
                {% if board_info %}
                    <span style="font-weight:normal; opacity:0.7; font-size: 0.8em;">/ {{ board_info.name }}</span>
                {% endif %}
            </h1>
            <form action="/search" method="get" class="search-form compact-search">
                <input type="text" name="query" placeholder="Поиск..." value="{{ query if query else '' }}">
                <button type="submit">🔍</button> 
            </form>
        </div>
        <div class="header-group-right">
            <div class="board-nav">
                {% for b_key, b_val in boards.items() %}
                    {% if b_key != 'test' %}
                        <a href="/{{ b_key }}/" class="{% if b_key == board_id %}active{% endif %}" title="{{ b_val.description[request.state.lang] if b_val.description is mapping else b_val.description }}">
                            /{{ b_key }}/
                        </a>
                    {% endif %}
                {% endfor %}
            </div>
            <div class="user-actions">
                {% if session.user and session.user.is_admin %}
                    <a href="/admin" class="header-btn admin-btn" title="Админ-панель">👮‍♂️</a>
                {% endif %}
                <a href="#" id="bottle-notification-btn" class="header-btn" style="display: none; position: relative;">✉️<span id="bottle-count"></span></a>
                <a href="#" id="favourites-btn" class="header-btn" title="{{ request.state.t('fav_title') }}">⭐</a>
                <button id="settings-btn" class="header-btn" title="{{ request.state.t('settings_btn_title') }}">⚙️</button>
                <button id="theme-toggle" class="theme-toggle-btn" title="{{ request.state.t('theme_btn_title') }}">🌙</button>
                {% if session.user %}
                    <a href="/auth/logout" class="logout-link">{{ request.state.t('logout_btn') }}</a>
                {% else %}
                    <a href="/login" class="header-btn" title="{{ request.state.t('login_btn') }}">🔑</a>
                {% endif %}
            </div>
        </div>
    </header>
    <main>
        <h2>{{ request.state.t('search_placeholder') }} «{{ query }}»</h2>
        <a href="/">{{ request.state.t('nav_main') }}</a>
        <hr>
        <div class="thread-list">
            {% if is_tag_search and search_images %}
                <div class="gallery-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 15px; padding: 10px;">
                    {% for file in search_images %}
                        <div class="gallery-item-wrapper" style="position: relative; border: 1px solid var(--border-primary); border-radius: 4px; overflow: hidden; background: var(--bg-post); display: flex; flex-direction: column;">
                            <a href="{{ file.original_url }}" 
                               class="gallery-item gallery-trigger"
                               data-type="{{ file.type }}"
                               data-filename="{{ file.filename }}"
                               data-file-id="{{ file.original_file_id }}"
                               style="display: block; height: 180px; overflow: hidden; position: relative;">
                                <div class="gallery-thumb" style="width: 100%; height: 100%;">
                                    {% if file.type in ['video', 'gif', 'animation', 'video_note'] or (file.type == 'sticker' and file.filename.endswith('.webm')) %}
                                        <video class="post-image lazy-load"
                                               preload="metadata"
                                               muted
                                               playsinline
                                               loop
                                               autoplay
                                               data-src="{{ file.original_url }}"
                                               {% if file.thumbnail_url %}poster="{{ file.thumbnail_url }}"{% endif %}
                                               style="width: 100%; height: 100%; object-fit: cover; background: #000;">
                                        </video>
                                    {% else %}
                                        <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" 
                                             data-src="{{ file.thumbnail_url or file.original_url }}" 
                                             class="post-image lazy-load" 
                                             alt="img" 
                                             referrerpolicy="no-referrer" 
                                             style="width: 100%; height: 100%; object-fit: cover;">
                                    {% endif %}
                                </div>
                                {% if file.type in ['video', 'gif', 'animation', 'video_note'] %}
                                    <span class="lazy-badge" style="position: absolute; bottom: 5px; right: 5px;">{{ 'GIF' if file.type in ['gif', 'animation'] else 'VIDEO' }}</span>
                                {% endif %}
                            </a>
                            <a href="/{{ file.parent_board_id }}/res/0#post-{{ file.parent_post_id }}" 
                               class="gallery-post-num" 
                               data-post-num="{{ file.parent_post_id }}"
                               target="_blank"
                               style="display: block; text-align: center; font-size: 0.85em; padding: 8px; background: var(--bg-hover); font-weight: bold; border-top: 1px solid var(--border-primary); text-decoration: none; color: var(--accent-primary);">
                               /{{ file.parent_board_id }}/ #{{ file.parent_post_id }}
                            </a>
                        </div>
                    {% endfor %}
                </div>
            {% elif posts %}
                {% for post in posts %}
                    <div class="post {% if post.author_id == session.user.id %}is-yours{% endif %}" id="post-{{ post.id }}" data-reports="{{ post.report_count }}">
                        <div class="post-header">
                            <span>/{{ post.board_id }}/ - Анон </span>
                            <span><a href="/{{ post.board_id }}/res/{{ post.thread_id or post.id }}.html#post-{{ post.id }}" class="post-num-link" target="_blank" rel="noopener noreferrer">#{{ post.id }}</a> {% if post.author_id == session.user.id %}<span class="you-marker">(You)</span>{% endif %}</span>
                            <span class="ts-recalc" data-ts="{{ post.timestamp }}">{{ post.timestamp | format_timestamp }}</span>
                        </div>
                        <div class="post-content">
                            {% if post.content.files %}
                            <div class="post-files-container post-gallery">
                                {% for file in post.content.files %}
                                    {% if file.type in ['image', 'photo', 'sticker'] %}
                                        {% if file.type == 'sticker' %}
                                            <div class="sticker-wrapper" style="display:inline-block; vertical-align:bottom;">
                                                <a href="{{ file.original_url }}" class="gallery-trigger" data-type="{{ 'video' if file.filename.endswith('.webm') else 'image' }}" data-filename="{{ file.filename }}">
                                                    {% if file.filename.endswith('.webm') %}
                                                        <video class="post-sticker" src="{{ file.original_url }}" autoplay loop muted playsinline webkit-playsinline referrerpolicy="no-referrer" style="max-height: 150px;"></video>
                                                    {% else %}
                                                        <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" data-src="{{ file.thumbnail_url or file.original_url }}" class="post-sticker lazy-load" referrerpolicy="no-referrer" style="max-height: 150px;">
                                                    {% endif %}
                                                </a>
                                            </div>
                                        {% else %}
                                            <a href="{{ file.original_url }}" class="file-thumb" data-filename="{{ file.filename }}">
                                                {% if file.blurhash %}
                                                    <canvas class="blurhash-canvas" data-hash="{{ file.blurhash }}" width="32" height="32"></canvas>
                                                {% endif %}
                                                <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" data-src="{{ file.thumbnail_url or file.original_url }}" class="post-image lazy-load" alt="img" referrerpolicy="no-referrer">
                                                {% if file.dupe_count is defined and file.dupe_count > 1 %}<div class="bayan-text">{{ file.dupe_count | bayan_label(request.state.lang) }}</div>{% endif %}
                                            </a>
                                        {% endif %}
                                    {% elif file.type in ['video', 'gif', 'animation'] %}
                                        <div class="file-thumb lazy-media-wrapper" 
                                             data-src="{{ file.original_url }}" 
                                             data-filename="{{ file.filename }}" 
                                             data-type="{{ 'gif' if file.type in ['gif', 'animation'] else 'video' }}">
                                            {% if file.blurhash %}
                                                <canvas class="blurhash-canvas" data-hash="{{ file.blurhash }}" width="32" height="32"></canvas>
                                            {% endif %}
                                            <video class="post-image lazy-load" 
                                                   preload="metadata" 
                                                   muted 
                                                   playsinline 
                                                   loop 
                                                   data-src="{{ file.original_url }}" 
                                                   {% if file.thumbnail_url %}poster="{{ file.thumbnail_url }}"{% endif %}
                                                   style="object-fit: cover; width: 100%; height: 100%; background: #000;">
                                            </video>
                                            <span class="lazy-badge">{{ 'GIF' if file.type in ['gif', 'animation'] else 'VIDEO' }}</span>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                            {% endif %}
                            <div class="post-text-content">
                                {% if post.reply_to_post_num %}
                                    <p class="reply-indicator"> Ответ на <a href="#post-{{ post.reply_to_post_num }}" class="post-link" data-post-num="{{ post.reply_to_post_num }}">&gt;&gt;{{ post.reply_to_post_num }}</a></p>
                                {% endif %}
                                <div class="post-text">{{ post.content.text | format_post_text | safe }}</div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <p>{{ request.state.t('no_posts') }}</p>
            {% endif %}
        </div>
    </main>
    <footer>
        <nav style="margin-bottom: 8px; display: flex; justify-content: center; gap: 20px;">
            <a href="/about/">[О проекте]</a>
            <a href="/faq/">[FAQ]</a>
        </nav>
        <p>{{ request.state.t('footer_text') }}</p>
    </footer>
    <div class="modal-overlay" id="modal-overlay" style="display: none;"></div>
    <div class="modal" id="quick-reply-modal" style="display: none;">
        <h3 id="qr-title">Ответ на пост #<span id="qr-post-num"></span></h3>
        <form id="quick-reply-form">
        </form>
    </div>
    <div class="modal" id="report-modal" style="display: none;">
        <h3>{{ request.state.t('report_modal_title') }} <span id="report-post-num"></span></h3>
        <form id="report-form">
            <div class="form-group">
                <label for="report-category">{{ request.state.t('report_category') }}</label>
                <select id="report-category" name="category" required>
                    <option value="Спам">{{ request.state.t('report_cat_spam') }}</option>
                    <option value="Оскорбление">{{ request.state.t('report_cat_insult') }}</option>
                    <option value="Нелегальный контент">{{ request.state.t('report_cat_illegal') }}</option>
                    <option value="Оффтоп">{{ request.state.t('report_cat_offtopic') }}</option>
                </select>
            </div>
            <div class="form-group">
                <label for="report-reason">{{ request.state.t('report_reason') }}</label>
                <textarea id="report-reason" name="reason" rows="3" required></textarea>
            </div>
            <input type="hidden" id="report-post-num-input" name="post_num">
            <button type="submit">{{ request.state.t('report_send') }}</button>
        </form>
    </div>
    <div class="modal" id="settings-modal" style="display: none;">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-separator); margin-bottom: 15px; padding-bottom: 10px;">
            <h3 style="margin: 0; border: none; padding: 0;">{{ request.state.t('settings_modal_title') }}</h3>
            <button type="button" onclick="document.getElementById('settings-modal').style.display='none'; document.getElementById('modal-overlay').style.display='none';" class="btn btn-secondary" style="font-size: 1.5em; line-height: 1; padding: 0 8px;">&times;</button>
        </div>
        <form id="settings-form">
            <div class="form-group">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                    <label for="setting-sound" style="margin:0; cursor: pointer;">🔊 {{ request.state.t('setting_sound') }}</label>
                    <input type="checkbox" id="setting-sound" data-setting="soundEnabled">
                </div>
            </div>
            <div class="form-group">
                <label for="setting-theme">{{ request.state.t('setting_theme') }}</label>
                <select id="setting-theme" data-setting="theme" class="form-control">
                    <option value="light">Светлая ☀️</option>
                    <option value="dark">Темная 🌙</option>
                    <option value="cyberpunk">Киберпанк 🌃</option>
                    <option value="crypto">Крипто ₿</option>
                    <option value="conan">Conan 🩸</option>
                    <option value="win95">Windows 95 💾</option>
                    <option value="gameboy">Gameboy 👾</option>
                    <option value="adventure">Adventure Time ⚔️</option>
                    <option value="luxury">Luxury Gold 🥂</option>
                    <option value="toxic">Toxic Acid ☢️</option>
                    <option value="shaft">Shaft / Monogatari ⛩️</option>
                    <option value="nord">Nord ❄️</option>
                    <option value="gruvbox">Gruvbox ☕</option>
                    <option value="discord">Discord 🎮</option>
                    <option value="lain">Lain / Wired 🌐</option>
                    <option value="dracula">Dracula 🧛</option>
                    <option value="sakura">Сакура 🌸</option>
                    <option value="ukraine">Украинская 🇺🇦</option>
                    <option value="soviet">Советская ☭</option>
                    <option value="paper">Бумажная 📜</option>
                    <option value="terminal">Терминал >_</option>
                    <option value="ocean">Океан 🌊</option>
                    <option value="forest">Лес 🌲</option>
                    <option value="gothic">Готика 🦇</option>
                    <option value="noir">Нуар ⚫</option>
                </select>
            </div>
            <div class="form-group">
                <label for="setting-font-size">{{ request.state.t('setting_font_size') }}</label>
                <select id="setting-font-size" data-setting="fontSize">
                    <option value="small">{{ request.state.t('setting_font_small') }}</option>
                    <option value="medium" selected>{{ request.state.t('setting_font_medium') }}</option>
                    <option value="large">{{ request.state.t('setting_font_large') }}</option>
                </select>
            </div>
            <div class="form-group">
                <label for="setting-preview-size">{{ request.state.t('setting_preview_size') }}</label>
                <select id="setting-preview-size" data-setting="previewSize">
                    <option value="small">{{ request.state.t('setting_font_small') }}</option>
                    <option value="medium" selected>{{ request.state.t('setting_font_medium') }}</option>
                    <option value="large">{{ request.state.t('setting_font_large') }}</option>
                </select>
            </div>
            <div class="form-group">
                <label for="setting-layout">{{ request.state.t('setting_layout') }}</label>
                <select id="setting-layout" data-setting="layoutMode">
                    <option value="center" selected>{{ request.state.t('setting_layout_center') }}</option>
                    <option value="wide">{{ request.state.t('setting_layout_wide') }}</option>
                    <option value="left">{{ request.state.t('setting_layout_left') }}</option>
                </select>
            </div>
            <div class="form-group">
                <label for="setting-density">{{ request.state.t('setting_density') }}</label>
                <select id="setting-density" data-setting="interfaceDensity">
                    <option value="normal" selected>{{ request.state.t('setting_density_norm') }}</option>
                    <option value="compact">{{ request.state.t('setting_density_compact') }}</option>
                </select>
            </div>
            <div class="form-group">
                <label for="setting-font-style">{{ request.state.t('setting_font_style') }}</label>
                <select id="setting-font-style" data-setting="fontStyle">
                    <option value="a">Verdana + Slab</option>
                    <option value="b" selected>Roboto + Verdana</option>
                </select>
            </div>
            <div class="form-group settings-row-checkbox" style="margin-top: 10px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <label for="setting-dim" style="margin:0;">{{ request.state.t('setting_nsfw') }}</label>
                    <input type="checkbox" id="setting-dim" data-setting="dimMode">
                </div>
            </div>
            <div class="form-group settings-row-checkbox">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <label for="setting-expand-images" style="margin:0;">Разворачивать картинки</label>
                    <input type="checkbox" id="setting-expand-images" data-setting="expandImages">
                </div>
            </div>
            <div class="form-group settings-row-checkbox">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <label for="setting-identicons" style="margin:0;">{{ request.state.t('setting_identicons') }}</label>
                    <input type="checkbox" id="setting-identicons" data-setting="showIdenticons">
                </div>
            </div>
            <div class="form-group settings-row-checkbox">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <label for="setting-mascot" style="margin:0;">Показывать Маскота</label>
                    <input type="checkbox" id="setting-mascot" data-setting="showMascot">
                </div>
            </div>
            <div style="margin-top: 20px; text-align: right;">
                <button type="button" onclick="document.getElementById('settings-modal').style.display='none'; document.getElementById('modal-overlay').style.display='none';" class="btn btn-primary modal-close-btn" style="width: 100%;">{{ request.state.t('btn_close') }}</button>
            </div>
        </form>
    </div>
    <div id="new-posts-indicator" style="display: none;"></div>
    <div id="image-viewer" class="image-viewer-overlay" style="display: none;">
        <span id="iv-close" class="iv-button iv-close-button">&times;</span>
        <span id="iv-prev" class="iv-button iv-nav-button iv-prev-button">&lsaquo;</span>
        <span id="iv-next" class="iv-button iv-nav-button iv-next-button">&rsaquo;</span>
        <div id="iv-container" class="iv-content-container"></div>
        <div id="iv-info" class="iv-info-bar">
            <a id="iv-download-link" href="#" target="_blank" download style="font-weight: bold; color: #64b5f6; margin-right: 10px;">[Скачать]</a>
            <a id="iv-filename" href="#" target="_blank" download>filename.jpg</a>
            <span id="iv-dimensions">1920x1080</span>
            <span id="iv-counter">1 / 10</span>
        </div>
        <div id="iv-loader" class="iv-loader" style="display: none;"></div>
    </div>
    <div id="loading-indicator" class="loading-indicator">Отправка...</div>
    <script src="/static/js/main.js?v=2.0" defer></script>
</body>
</html>