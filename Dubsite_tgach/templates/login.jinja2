<!DOCTYPE html>
<html lang="{{ request.state.lang or 'ru' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ТГАЧ - Вход</title>
    <link rel="stylesheet" href="/static/css/style.css?v=3.11">
    <link rel="icon" href="/static/favicon.ico">
    <style>
        body { 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            min-height: 100vh; 
            text-align: left; 
            padding: 20px 0;
            background-color: var(--bg-page);
            color: var(--text-primary); 
        }
        .login-container { 
            padding: 30px 40px; 
            border-radius: 8px; 
            width: 100%; 
            max-width: 600px; 
            background-color: var(--bg-main); 
            border: 1px solid var(--border-primary);
            box-shadow: var(--shadow-main);
        }
        .login-container h1 { 
            color: var(--accent-primary); 
            margin-top: 0; 
            text-align: center; 
            font-family: var(--font-headings);
        }
        .login-container p, .login-container li { 
            color: var(--text-primary); 
            font-size: 15px; 
        }
        /* Вторичный текст */
        .text-muted, .info-block li, .login-container p i {
            color: var(--text-secondary);
        }
        .login-container hr { 
            border-top: 1px solid var(--border-separator); 
            margin: 25px 0; 
        }
        #token-input { 
            width: 95%; 
            text-align: center; 
            margin-bottom: 15px !important; 
            /* Стили инпута уже есть в style.css, но можно уточнить */
            background-color: var(--bg-input);
            color: var(--text-primary);
            border: 1px solid var(--border-input);
        }
        #login-error { 
            color: var(--action-danger); 
            display: none; 
            margin-top: 10px; 
            text-align: center; 
        }
        .info-block { margin-top: 25px; }
        .info-block h3 { 
            margin-bottom: 10px; 
            color: var(--accent-primary);
            font-family: var(--font-headings);
        }
        .info-block ul { padding-left: 20px; }
        /* Кнопки берем из style.css (.btn-primary), но если нужны инлайн: */
        .btn-special {
            background-color: var(--accent-primary);
            color: var(--text-button);
        }
        .btn-special:hover {
            background-color: var(--accent-primary-hover);
        }
        /* Ссылка "Вернуться" */
        .back-link {
            font-size: 0.9em; 
            color: var(--text-secondary); 
            text-decoration: none;
        }
        .back-link:hover {
            color: var(--accent-link);
        }
    </style>
</head>
<img src="/static/img/mascot/mascot_login.png" class="corner-mascot" alt="">
<body {% if session.user %}data-user-id="{{ request.state.user_hash }}"{% endif %} data-site-mode="{{ site_mode }}">
    <script>
        (function() {
            try {
                var settings = JSON.parse(localStorage.getItem('user_settings') || '{}');
                var theme = settings.theme || localStorage.getItem('theme');
                if (!theme) {
                    if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) theme = 'dark';
                    else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) theme = 'light';
                    else theme = Math.random() < 0.5 ? 'dark' : 'light';
                    localStorage.setItem('theme', theme);
                }
                if (theme && theme !== 'light') {
                    if (document.body) document.body.classList.add('theme-' + theme);
                    else document.addEventListener('DOMContentLoaded', function() {
                        document.body.classList.add('theme-' + theme);
                    });
                }
                var fontStyle = settings.fontStyle || 'b';
                if (fontStyle === 'b') document.body.classList.add('font-style-b');
                var fontSize = settings.fontSize;
                if (!fontSize) {
                    if (window.innerWidth <= 768) fontSize = 'small';
                    else fontSize = 'medium';
                }
                document.body.classList.add('font-size-' + fontSize);
            } catch (e) { console.error(e); }
        })();
    </script>
    <div class="login-container">
        <h1>{{ request.state.t('login_title') }}</h1>
        <p style="text-align: center;"><i>{{ request.state.t('login_instruction') }}</i></p>
        <div style="text-align: center; margin: 15px 0;">
            <a href="https://t.me/{{ BOT_USERNAME }}?start=token_request" target="_blank" class="btn btn-primary" style="font-size: 1.1em;"><b>{{ request.state.t('get_token_btn').format(bot=BOT_USERNAME) }}</b></a>
        </div>
        <hr>
        <form id="login-form" style="text-align: center;">
            <input type="text" id="token-input" placeholder="{{ request.state.t('token_placeholder') }}">
            <button type="submit" class="btn btn-primary">{{ request.state.t('login_submit') }}</button>
        </form>
        <div style="text-align: center; margin-top: 15px;">
            <a href="/" class="back-link">&larr; {{ request.state.t('login_guest_back') }}</a>
        </div>
        <p id="login-error"></p>
        <div class="info-block">
            <h3>{{ request.state.t('login_what_is') }}</h3>
            <p>ТГАЧ — это гибридная анонимная имиджборда.</p>
            <h3>Зачем нужен токен?</h3>
            <ul>
                <li><b>Анонимность:</b> Токен — это твой ключ. Мы не храним пароли.</li>
                <li><b>Защита:</b> Помогает нам бороться со спам-ботами.</li>
                <li><b>Удобство:</b> Браузер запомнит токен, и вводить его каждый раз не нужно.</li>
            </ul>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const loginForm = document.getElementById('login-form');
            const tokenInput = document.getElementById('token-input');
            const errorP = document.getElementById('login-error');
            const savedToken = localStorage.getItem('api_token');
            if (savedToken) {
                tokenInput.value = savedToken;
            }
            loginForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                errorP.style.display = 'none';
                const token = tokenInput.value.trim();
                if (!token) {
                    errorP.textContent = "{{ request.state.t('login_err_empty') }}";
                    errorP.style.display = 'block';
                    return;
                }
                try {
                    const response = await fetch('/auth/token', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ token: token })
                    });
                    if (response.ok) {
                        localStorage.setItem('api_token', token);
                        window.location.href = '/';
                    } else {
                        const errorData = await response.json();
                        errorP.textContent = `Ошибка: ${errorData.detail}`;
                        errorP.style.display = 'block';
                    }
                } catch (err) {
                    errorP.textContent = "{{ request.state.t('login_err_net') }}";
                    errorP.style.display = 'block';
                }
            });
        });
    </script>
</body>
</html>