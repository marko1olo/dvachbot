<!DOCTYPE html>
<html lang="{{ request.state.lang or 'ru' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ board_info.name }} Чатик - {{ request.state.t('site_name') }}</title>
    <link rel="stylesheet" href="/static/css/style.css?v=2.9">
    <link rel="icon" href="/static/favicon.ico">
    <meta property="og:site_name" content="ТГАЧ">
    <meta property="og:type" content="website">
    <meta property="og:title" content="/{{ board_id }}/ — {{ board_info.name }}">
    <meta property="og:description" content="{{ board_info.description }}">
    <meta property="og:url" content="{{ request.url }}">
    <meta property="og:image" content="{{ request.base_url }}static/logo.png">
    <link rel="manifest" href="/static/manifest.json">
    <meta name="theme-color" content="#212121">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, interactive-widget=resizes-content">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="/static/icons/icon-192.png">
    <link rel="preconnect" href="https://api.telegram.org" crossorigin>
    <link rel="dns-prefetch" href="https://files.catbox.moe">
    <link rel="dns-prefetch" href="https://huggingface.co">
    <link rel="preconnect" href="https://huggingface.co" crossorigin>
    <style>
        .file-btn-icon { display: none; }
        .file-btn-text { display: inline; }
        @media (max-width: 768px) {
            .file-btn-text { display: none; }
            .file-btn-icon { display: inline; font-size: 1.2em; }
        }
        #post-form.drag-over::after {
            content: "{{ request.state.t('drag_hint') }}" !important;
        }
        .post.hidden::after {
            content: "{{ request.state.t('post_hidden_hint') }}" !important;
        }
    </style>
</head>
<body {% if session.user %}data-user-id="{{ request.state.user_hash }}"{% endif %} data-site-mode="{{ site_mode }}" data-is-admin="{{ 'true' if session.user and session.user.is_admin else 'false' }}" data-user-role="{{ session.user.role if session.user else 'user' }}">
    <div id="app-loader">
        <div class="loader-content">
            <img src="/static/logo.png" alt="TGACH" width="80" height="80">
            <div class="loader-spinner"></div>
        </div>
    </div>
    <script>
        (function() {
            try {
                var settings = JSON.parse(localStorage.getItem('user_settings') || '{}');
                // 1. ТЕМА
                var theme = settings.theme || localStorage.getItem('theme');
                if (!theme) {
                    if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) theme = 'dark';
                    else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) theme = 'light';
                    else theme = Math.random() < 0.5 ? 'dark' : 'light';
                    localStorage.setItem('theme', theme);
                }
                if (theme && theme !== 'light') {
                    if (document.body) document.body.classList.add('theme-' + theme);
                    else document.addEventListener('DOMContentLoaded', function() {
                        document.body.classList.add('theme-' + theme);
                    });
                }
                // 2. СТИЛЬ ШРИФТА (Roboto/Verdana)
                var fontStyle = settings.fontStyle || 'b';
                if (fontStyle === 'b') document.body.classList.add('font-style-b');
                // 3. РАЗМЕР ШРИФТА (АВТОМАТИЧЕСКИЙ ДЛЯ МОБИЛОК)
                var fontSize = settings.fontSize;
                if (!fontSize) {
                    // Если настройки нет, смотрим на ширину экрана прямо сейчас
                    if (window.innerWidth <= 768) fontSize = 'small';
                    else fontSize = 'medium';
                }
                document.body.classList.add('font-size-' + fontSize);
            } catch (e) { console.error(e); }
        })();
    </script>
    <header>
        <div class="board-nav-top">
            <a href="/overboard/" title="Все треды">/all/</a>

            {% for category in ['popular', 'bio', 'thematic', 'system'] %}
                {% set category_boards = [] %}
                {% for b_key, b_val in boards.items() %}
                    {% if b_val.category == category %}{% set _ = category_boards.append(b_key) %}{% endif %}
                {% endfor %}
                
                {% if category_boards %}
                    <span style="opacity:0.3; margin-left:8px;">[</span>
                    {% for b_key in category_boards %}
                        <a href="/{{ b_key }}/threads/" class="{% if b_key == board_id %}active{% endif %}" title="{{ boards[b_key].name }}">
                            {{ boards[b_key].name }}
                        </a>
                    {% endfor %}
                    <span style="opacity:0.3; margin-right:8px;">]</span>
                {% endif %}
            {% endfor %}
        </div>
        <div class="header-main-row">
            <div class="header-logo" style="display: flex; align-items: center; gap: 15px;">
                <h1>
                    <a href="/">ТГАЧ</a> 
                </h1>
                <span style="font-family: var(--font-headings); font-weight:bold; font-size: 1.2em; color: var(--text-secondary);">
                    {{ board_info.name }} <span style="font-size:0.8em; opacity:0.7;">(Чат)</span>
                </span>
                
                <form action="/search" method="get" class="search-form compact-search" style="margin-left: 10px;">
                    <input type="text" name="query" placeholder="Поиск..." value="">
                    <button type="submit" style="padding: 4px 8px;">🔍</button>
                </form>
            </div>
            <div class="header-group-right">
                <div class="user-actions">
                    {% if session.user and session.user.is_admin %}
                        <a href="/admin" class="header-btn admin-btn">👮‍♂️</a>
                    {% endif %}
                    <a href="#" id="bottle-notification-btn" class="header-btn" style="display:none;">✉️<span id="bottle-count"></span></a>
                    <a href="#" id="favourites-btn" class="header-btn" title="{{ request.state.t('fav_title') }}">⭐</a>
                    <button id="settings-btn" class="header-btn" title="{{ request.state.t('settings_btn_title') }}">⚙️</button>
                    <button id="theme-toggle" class="theme-toggle-btn" title="{{ request.state.t('theme_btn_title') }}">🌙</button>
                    {% if session.user %}
                        <a href="/auth/logout" class="logout-link">{{ request.state.t('logout_btn') }}</a>
                    {% else %}
                        <a href="/login" class="header-btn">🔑</a>
                    {% endif %}
                </div>
            </div>
        </div>
        <nav class="board-header-nav">
            <a href="/">[{{ request.state.t('nav_home') }}]</a>
            <span class="nav-sep">|</span>
            <a href="/{{ board_id }}/mode/">[{{ request.state.t('nav_mode_select') }}]</a>
            <div class="mobile-break"></div>
            <span class="nav-sep">|</span>
            <a href="/{{ board_id }}/threads/">[{{ request.state.t('nav_threads') }}]</a>
            <a href="/{{ board_id }}/chat/" class="active">[{{ request.state.t('nav_chat') }}]</a>
            <a href="/{{ board_id }}/catalog/">[{{ request.state.t('nav_catalog') }}]</a>
            {% if board_info.username %}
            <a href="https://t.me/{{ board_info.username.lstrip('@') }}" target="_blank" class="tg-link">[{{ request.state.t('nav_tg') }}]</a>
            {% endif %}
            <span class="nav-sep">|</span>
            <a href="#" class="gallery-trigger">[{{ request.state.t('nav_gallery') }}]</a>
        </nav>
    </header>
    <main>
        <h3>Написать в чат</h3>
        <form id="post-form">
            <input type="text" name="email" class="hp-field" autocomplete="off" tabindex="-1">
            <input type="text" name="username" class="name-field" autocomplete="off" tabindex="-1">
            <div class="form-fields">
                 <div class="format-buttons">
                    <button type="button" class="format-btn" data-tag="b" title="{{ request.state.t('form_btn_bold') }}"><b>B</b></button>
                    <button type="button" class="format-btn" data-tag="i" title="{{ request.state.t('form_btn_italic') }}"><i>I</i></button>
                    <button type="button" class="format-btn" data-tag="s" title="{{ request.state.t('form_btn_strike') }}"><s>S</s></button>
                    <button type="button" class="format-btn" data-tag="spoiler" title="{{ request.state.t('form_btn_spoiler') }}">Spoiler</button>
                    <span style="border-left: 1px solid var(--border-input); margin: 0 5px;"></span>
                    <button type="button" class="format-btn" data-tag="shake" title="{{ request.state.t('form_btn_shake') }}">😵</button>
                    <button type="button" class="format-btn" data-tag="rainbow" title="{{ request.state.t('form_btn_rainbow') }}">🌈</button>
                    <button type="button" class="format-btn" data-tag="blur" title="{{ request.state.t('form_btn_blur') }}">🌫️</button>
                    <button type="button" class="format-btn" data-tag="glitch" title="{{ request.state.t('form_btn_glitch') }}">👾</button>
                    <button type="button" class="format-btn" id="help-tags-btn" title="{{ request.state.t('form_btn_help') }}" ...>❓</button>
                </div>
                <textarea id="post-text" name="text" placeholder="{{ request.state.t('form_text_placeholder') }}" rows="4" cols="50"></textarea>
                <div id="file-preview-container" class="file-preview-container"></div>
                <div id="poll-creator-container" class="poll-creator">
                    <input type="text" name="poll_question" placeholder="Вопрос опроса..." maxlength="255">
                    <div id="poll-options-container" class="poll-options-container">
                        <div class="poll-option">
                            <input type="text" name="poll_options" placeholder="Вариант 1" maxlength="100">
                        </div>
                        <div class="poll-option">
                            <input type="text" name="poll_options" placeholder="Вариант 2" maxlength="100">
                        </div>
                    </div>
                    <div class="poll-controls">
                        <button id="add-poll-option">+ Добавить вариант</button>
                    </div>
                </div>
            </div>
            <div class="form-controls">
                <label for="file-input" class="file-input-label">
                    <span class="file-btn-text">{{ request.state.t('btn_attach') }}</span>
                    <span class="file-btn-icon">📎</span>
                </label>
                <label class="picrandom-container" title="Прикрепить случайную картинку из архива">
                    <input type="checkbox" name="picrandom" value="true">
                    <span class="picrandom-icon">🎲</span>
                    <span class="picrandom-label">Rand</span>
                </label>
                <input type="file" id="file-input" name="images" accept="image/*,video/mp4,video/webm" multiple style="display: none;">
                <input type="hidden" name="board_id" value="{{ board_id }}">
                <input type="hidden" name="reply_to" value="">
                <button type="button" id="toggle-poll-creator" class="btn btn-secondary" title="Создать опрос" style="margin-right: 5px;">📊</button>
                <input type="hidden" name="post_mode" value="chat_post">
                <button type="submit">Отправить</button>
                <div class="loading-indicator-inline">Отправка...</div>
            </div>
        </form>
        <hr>
        <div class="chat-list">
            {% if posts %}
                {% for post in posts %}
                <div class="post {% if post.content.sage %}is-sage{% endif %} {% if post.author_id == session.user.id %}is-yours{% endif %}" id="post-{{ post.id }}">
                    <div class="post-header">
                        <canvas class="identicon" data-userid="{{ post.author_id }}" width="20" height="20"></canvas>
                        <span>{{ request.state.t('anon_name') }} </span>
                        <span>
                            {% if post.thread_id %}
                                <a href="/{{ board_id }}/res/{{ post.thread_id }}.html#post-{{ post.id }}" class="post-num-link">#{{ post.id }}</a>
                            {% else %}
                                <a href="#post-{{ post.id }}" class="post-num-link">#{{ post.id }}</a>
                            {% endif %}
                            {% if post.author_id == session.user.id %}<span class="you-marker">(You)</span>{% endif %}
                        </span>
                        <span class="ts-recalc" data-ts="{{ post.timestamp }}">{{ post.timestamp | format_timestamp }}</span>
                        {% if post.content.sage %}<span class="sage-indicator">SAGE</span>{% endif %}
                        <div class="post-actions">
                            <button class="action-menu-trigger" 
                                data-post-num="{{ post.id }}" 
                                data-board-id="{{ board_id }}" 
                                data-thread-id="{{ post.thread_id or '' }}" 
                                data-author-id="{{ post.author_id }}">
                                ▶
                            </button>
                        </div>
                    </div>
                    <div class="post-content">
                        {% if post.content.type == 'files' and post.content.files %}
                            <div class="post-files-container post-gallery">
                                {% for file in post.content.files %}
                                    {% if file.type in ['image', 'photo', 'sticker', 'video_note', 'video', 'gif', 'animation'] %}
                                                {% if file.type == 'image' or file.type == 'photo' %}
                                                    <a href="{{ file.original_url }}" class="file-thumb" data-filename="{{ file.filename }}" data-file-id="{{ file.original_file_id }}">
                                                        <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" 
                                                            data-src="{{ file.thumbnail_url or file.original_url }}" 
                                                            class="post-image lazy-load" alt="img" referrerpolicy="no-referrer">
                                                    </a>
                                                {% elif file.type == 'sticker' %}
                                                    <div class="sticker-wrapper" style="display:inline-block; vertical-align:bottom;">
                                                        <a href="{{ file.original_url }}" class="gallery-trigger" data-type="{{ 'video' if file.filename.endswith('.webm') else 'image' }}" data-filename="{{ file.filename }}" data-file-id="{{ file.original_file_id }}">
                                                            {% if file.filename.endswith('.webm') %}
                                                                <video class="post-sticker" 
                                                                       src="{{ file.original_url }}" 
                                                                       autoplay loop muted playsinline webkit-playsinline 
                                                                       referrerpolicy="no-referrer" 
                                                                       style="max-height: 150px; width: auto; background: transparent; display: block;">
                                                                </video>
                                                            {% else %}
                                                                <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" 
                                                                    data-src="{{ file.thumbnail_url or file.original_url }}" 
                                                                    class="post-sticker lazy-load" 
                                                                    onclick="event.stopPropagation();" 
                                                                    referrerpolicy="no-referrer"
                                                                    onerror="handleImageError(this)">
                                                            {% endif %}
                                                        </a>
                                                    </div>
                                                {% elif file.type == 'video_note' %}
                                                    <video class="post-video video-note" 
                                                           src="{{ file.original_url }}" 
                                                           autoplay 
                                                           loop 
                                                           muted 
                                                           playsinline 
                                                           onclick="event.preventDefault(); event.stopPropagation(); this.paused ? this.play() : this.pause();"
                                                           style="border-radius: 50%; object-fit: cover;" 
                                                           referrerpolicy="no-referrer">
                                                    </video>
                                                {% elif file.type in ['video', 'gif', 'animation'] %}
                                                    <div class="file-thumb lazy-media-wrapper" 
                                                        data-src="{{ file.original_url }}" 
                                                        data-filename="{{ file.filename }}"
                                                        data-type="{{ 'gif' if file.type in ['gif', 'animation'] else 'video' }}">
                                                        {% if file.blurhash %}
                                                            <canvas class="blurhash-canvas" data-hash="{{ file.blurhash }}" width="32" height="32"></canvas>
                                                        {% endif %}
                                                        <video class="post-image lazy-load" 
                                                               preload="metadata" 
                                                               muted 
                                                               playsinline
                                                               loop
                                                               data-src="{{ file.original_url }}"
                                                               {% if file.thumbnail_url %}poster="{{ file.thumbnail_url }}"{% endif %}
                                                               style="object-fit: cover; width: 100%; height: 100%; background: #000;">
                                                        </video>
                                                        <span class="lazy-badge">{{ 'GIF' if file.type in ['gif', 'animation'] else 'VIDEO' }}</span>
                                                    </div>
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                            </div>
                            <div class="post-audios-container">
                                {% for file in post.content.files %}
                                    {% if file.type in ['audio', 'voice', 'document'] %}
                                        {% if file.type == 'audio' or file.type == 'voice' %}
                                            {% set unique_id = 'audio-' ~ post.id ~ '-' ~ loop.index %}
                                            <div class="custom-audio-player" id="player-{{ unique_id }}" data-src="{{ file.original_url }}">
                                                <audio id="{{ unique_id }}" preload="none"><source src="{{ file.original_url }}" type="{{ file.mime_type or 'audio/mpeg' }}"></audio>
                                                <button class="cap-play-btn" data-target="{{ unique_id }}" type="button">▶</button>
                                                <div class="cap-info"><span class="cap-time">00:00</span></div>
                                                <div class="cap-progress-container" data-target="{{ unique_id }}"><div class="cap-wave-base"></div><div class="cap-wave-progress"></div></div>
                                                <div class="cap-info"><button class="cap-speed-btn" data-target="{{ unique_id }}" type="button">1x</button></div>
                                                <a href="{{ file.original_url }}" download="{{ file.filename }}" class="cap-download-btn">⬇</a>
                                            </div>
                                        {% elif file.type == 'document' %}
                                            <div style="margin-top:5px;">
                                                <a href="{{ file.original_url }}" target="_blank" class="file-document-link">📄 {{ file.filename }}</a>
                                            </div>
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}
                        
                        <div class="post-text-content">
                            {% if post.reply_to_post_num %}
                                <a href="#post-{{ post.reply_to_post_num }}" class="post-link" data-post-num="{{ post.reply_to_post_num }}" style="color:var(--accent-link); text-decoration:none; font-weight:bold;">&gt;&gt;{{ post.reply_to_post_num }}</a><br>
                            {% endif %}
                            {% if post.content.poll_data %}
                                {{ post.content.poll_data | format_poll | safe }}
                            {% else %}
                                <div class="post-text">{{ post.content.text | format_post_text | safe }}</div>
                            {% endif %}
                            <div class="backlinks-container" id="backlinks-for-{{ post.id }}">
                                {% if post.backlinks %}
                                    {% for backlink_id in post.backlinks %}
                                        <a href="#post-{{ backlink_id }}" class="post-link" data-post-num="{{ backlink_id }}">&gt;&gt;{{ backlink_id }}</a>
                                    {% endfor %}
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <p>На этой доске пока нет сообщений. Напишите первым!</p>
            {% endif %}
        </div>
        <div id="chat-loading-indicator" class="chat-loader">
            <p>Загрузка старых сообщений...</p>
        </div>
    </main>
    <div id="image-viewer" class="image-viewer-overlay" style="display: none;">
        <span id="iv-close" class="iv-button iv-close-button">&times;</span>
        <span id="iv-prev" class="iv-button iv-nav-button iv-prev-button">&lsaquo;</span>
        <span id="iv-next" class="iv-button iv-nav-button iv-next-button">&rsaquo;</span>
        <div id="iv-container" class="iv-content-container"></div>
        <div id="iv-info" class="iv-info-bar">
            <a id="iv-download-link" href="#" target="_blank" download style="font-weight: bold; color: #64b5f6; margin-right: 10px;">[Скачать]</a>
            <a id="iv-filename" href="#" target="_blank" download>filename.jpg</a>
            <span id="iv-dimensions">1920x1080</span>
            <span id="iv-counter">1 / 10</span>
        </div>
        <div id="iv-loader" class="iv-loader" style="display: none;"></div>
    </div>
    <footer>
        <nav style="margin-bottom: 8px; display: flex; justify-content: center; gap: 20px;">
            <a href="/about/">{{ request.state.t('nav_about') }}</a>
            <a href="/faq/">{{ request.state.t('nav_faq') }}</a>
            <a href="/rules/">{{ request.state.t('nav_rules') }}</a>
            <a href="#" onclick="event.preventDefault(); openModal('feedback-modal');">✉️ Связь</a>
            <a href="/tv/random" style="color: var(--accent-primary); font-weight: bold;">[WebM]</a>
            <a href="/img/random" style="color: var(--accent-primary); font-weight: bold;">[IMG]</a>
        </nav>
        <p>{{ request.state.t('footer_text') }}</p>
    </footer>
    <div class="modal-overlay" id="modal-overlay" style="display: none !important;"></div>
    <div class="modal" id="quick-reply-modal" style="display: none !important;"></div>
    <div class="modal" id="report-modal" style="display: none !important;">
        <h3>Жалоба на пост <span id="report-post-num"></span></h3>
        <form id="report-form">
            <div class="form-group">
                <label for="report-category">Категория:</label>
                <select id="report-category" name="category" required>
                    <option value="Спам">Спам</option>
                    <option value="Оскорбление">Оскорбление</option>
                    <option value="Нелегальный контент">Нелегальный контент</option>
                    <option value="Оффтоп">Оффтоп</option>
                </select>
            </div>
            <div class="form-group">
                <label for="report-reason">Причина:</label>
                <textarea id="report-reason" name="reason" rows="3" required></textarea>
            </div>
            <input type="hidden" id="report-post-num-input" name="post_num">
            <button type="submit">Отправить</button>
        </form>
    </div>
    <div class="modal" id="settings-modal" style="display: none;">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-separator); margin-bottom: 15px; padding-bottom: 10px;">
            <h3 style="margin: 0; border: none; padding: 0;">{{ request.state.t('settings_modal_title') }}</h3>
            <button type="button" onclick="document.getElementById('settings-modal').style.display='none'; document.getElementById('modal-overlay').style.display='none';" class="btn btn-secondary" style="font-size: 1.5em; line-height: 1; padding: 0 8px;">&times;</button>
        </div>
        <form id="settings-form">
            <div class="form-group">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                    <label for="setting-sound" style="margin:0; cursor: pointer;">🔊 {{ request.state.t('setting_sound') }}</label>
                    <input type="checkbox" id="setting-sound" data-setting="soundEnabled">
                </div>
            </div>
            <div class="form-group">
                <label for="setting-theme">{{ request.state.t('setting_theme') }}</label>
                <select id="setting-theme" data-setting="theme" class="form-control">
                    <option value="light">{{ request.state.t('theme_light') }}</option>
                    <option value="dark">{{ request.state.t('theme_dark') }}</option>
                    <option value="cyberpunk">{{ request.state.t('theme_cyberpunk') }}</option>
                    <option value="crypto">{{ request.state.t('theme_crypto') }}</option>
                    <option value="conan">{{ request.state.t('theme_conan') }}</option>
                    <option value="win95">{{ request.state.t('theme_win95') }}</option>
                    <option value="gameboy">{{ request.state.t('theme_gameboy') }}</option>
                    <option value="adventure">{{ request.state.t('theme_adventure') }}</option>
                    <option value="luxury">{{ request.state.t('theme_luxury') }}</option>
                    <option value="toxic">{{ request.state.t('theme_toxic') }}</option>
                    <option value="shaft">{{ request.state.t('theme_shaft') }}</option>
                    <option value="nord">{{ request.state.t('theme_nord') }}</option>
                    <option value="gruvbox">{{ request.state.t('theme_gruvbox') }}</option>
                    <option value="discord">{{ request.state.t('theme_discord') }}</option>
                    <option value="lain">{{ request.state.t('theme_lain') }}</option>
                    <option value="dracula">{{ request.state.t('theme_dracula') }}</option>
