    <div class="modal" id="bottle-modal" style="display: none;">
        <h3>Отправить записку анону</h3>
        <form id="bottle-form">
            <div class="form-group">
                <textarea id="bottle-text" name="text" rows="4" maxlength="280" placeholder="Ваше анонимное послание (до 280 символов)..." required></textarea>
                <small style="color: var(--text-secondary);">Это увидят только вы и получатель. Сообщение самоуничтожится после прочтения.</small>
            </div>
            <input type="hidden" id="bottle-post-num-input" name="post_num">
            <div style="display: flex; justify-content: flex-end; gap: 10px;">
                <button type="button" id="bottle-cancel-btn" class="btn btn-secondary">Отмена</button>
                <button type="submit" class="btn btn-primary">Отправить</button>
            </div>
        </form>
    </div>
    <div class="modal" id="help-modal" style="display: none; max-width: 600px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; border-bottom: 1px solid var(--border-primary); padding-bottom: 10px;">
            <h3 style="margin: 0; border: none;">{{ request.state.t('help_title') }}</h3>
            <button class="btn btn-secondary modal-close-btn" style="font-size: 1.5em; line-height: 1; padding: 0 8px;">&times;</button>
        </div>
        <div class="help-content" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            <div>
                <h4 style="margin-top: 0; color: var(--text-secondary);">{{ request.state.t('help_basics') }}</h4>
                <ul style="list-style: none; padding: 0; line-height: 1.8;">
                    <li><code>[b]Текст[/b]</code> → <b>Жирный</b></li>
                    <li><code>[i]Текст[/i]</code> → <i>Курсив</i></li>
                    <li><code>[s]Текст[/s]</code> → <s>Зачеркнутый</s></li>
                    <li><code>||Текст||</code> → <span class="spoiler">Спойлер</span></li>
                </ul>
            </div>
            <div>
                <h4 style="margin-top: 0; color: var(--text-secondary);">{{ request.state.t('help_effects') }}</h4>
                <ul style="list-style: none; padding: 0; line-height: 1.8;">
                    <li><code>[shake]...[/shake]</code> → <span class="effect-shake">Тряска</span></li>
                    <li><code>[rainbow]...[/rainbow]</code> → <span class="effect-rainbow">Наримашка</span></li>
                    <li><code>[blur]...[/blur]</code> → <span class="effect-blur">Сосал?</span> (Наведи)</li>
                    <li><code>[glitch]...[/glitch]</code> → <span class="effect-glitch" data-text="Глитч">Глитч</span></li>
                </ul>
            </div>
        </div>
        <div style="margin-top: 15px; text-align: right;">
            <button class="btn btn-secondary modal-close-btn" style="font-size: 1.5em; line-height: 1; padding: 0 8px;">&times;</button>
        </div>
    </div>
    <div class="modal" id="shadow-ban-modal" style="display: none;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; border-bottom: 1px solid var(--border-primary); padding-bottom: 10px;">
            <h3 style="margin: 0; border: none;">{{ request.state.t('shadow_modal_title') }}</h3>
            <button onclick="document.getElementById('shadow-ban-modal').style.display='none'; document.getElementById('modal-overlay').style.display='none';" class="btn btn-secondary" style="font-size: 1.5em; line-height: 1; padding: 0 8px;">&times;</button>
        </div>
        <form id="shadow-ban-form">
            <input type="hidden" id="shadow-ban-post-num" name="post_num">
            <div class="form-group">
                <label>{{ request.state.t('shadow_duration') }}</label>
                <select name="duration" class="form-control">
                    <option value="3600">1 час</option>
                    <option value="86400" selected>24 часа</option>
                    <option value="604800">7 дней</option>
                    <option value="2592000">30 дней</option>
                </select>
            </div>
            <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px;">
                <button type="button" onclick="document.getElementById('shadow-ban-modal').style.display='none'; document.getElementById('modal-overlay').style.display='none';" class="btn btn-secondary">{{ request.state.t('btn_cancel') }}</button>
                <button type="submit" class="btn btn-primary" style="background-color: purple; border-color: purple;">{{ request.state.t('btn_shadow_confirm') }}</button>
            </div>
        </form>
    </div>
